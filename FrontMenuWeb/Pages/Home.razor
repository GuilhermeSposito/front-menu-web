    private async Task CarregarEstatisticasCaixaAtual()
    {
        if (EstatisticasCaixaCarregadas) return;
        CarregandoEstatisticasCaixa = true;
        StateHasChanged();

        try
        {
            var retorno = await CaixaService.GetItensProdutosVendidosNoCaixaAtualAsync(limit: LimitItensCaixa);
            if (retorno?.Status == "success" && retorno.Data is not null)
            {
                EstatisticasCaixaAtual = retorno.Data;

                var top6 = EstatisticasCaixaAtual.Itens.Take(6).ToList();
                var dataList = top6.Select(i => i.PorcentagemDasVendas).ToList();
                var labelsList = top6.Select(i => i.Descricao).ToList();

                var outros = EstatisticasCaixaAtual.Itens.Skip(6).Sum(i => i.PorcentagemDasVendas);
                if (outros > 0)
                {
                    dataList.Add(Math.Round(outros, 2, MidpointRounding.AwayFromZero));
                    labelsList.Add("Outros");
                }

                dataItensCaixaAtual = dataList.ToArray();
                labelsItensCaixaAtual = labelsList.ToArray();
                EstatisticasCaixaCarregadas = true;
            }
            else
            {
                Snackbar.Add("Erro ao carregar estatísticas do caixa.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao carregar estatísticas do caixa: {ex.Message}", Severity.Error);
        }
        finally
        {
            CarregandoEstatisticasCaixa = false;
            StateHasChanged();
        }
    }

    private async Task OnLimitItensCaixaChanged(int novoLimit)
    {
        LimitItensCaixa = novoLimit;
        EstatisticasCaixaCarregadas = false;
        await CarregarEstatisticasCaixaAtual();
    }

