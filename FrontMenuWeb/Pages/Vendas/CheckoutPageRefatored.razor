    // ── Autocomplete / busca ────────────────────────────────────
    private async Task<IEnumerable<ClsProduto>> BuscarProdutosAutocomplete(string texto, CancellationToken ct)
    {
        _pesquisaAtual = texto ?? string.Empty;
        if (string.IsNullOrWhiteSpace(texto)) return [];

        // N* → define quantidade para o próximo item
        if (texto.EndsWith("*"))
        {
            var numStr = texto[..^1].Trim();
            if (int.TryParse(numStr, out int qtd) && qtd > 0)
            {
                await InvokeAsync(async () =>
                {
                    _quantidade = qtd;
                    _pesquisaAtual = string.Empty;
                    _itemAtual = null;
                    await _autocompleteRef.ClearAsync();
                    StateHasChanged();
                });
            }
            return [];
        }
        
        // c*numero → carregar mesa pelo código externo
        if (texto.StartsWith("c*", StringComparison.OrdinalIgnoreCase))
        {
            var numStr = texto.Substring(2).Trim();
            if (int.TryParse(numStr, out int codExterno))
            {
                await InvokeAsync(async () => await CarregarMesaParaCheckout(codExterno: codExterno));
                return [];
            }
        }

        // ca*apelido → carregar mesa pelo apelido
        if (texto.StartsWith("ca*", StringComparison.OrdinalIgnoreCase))
        {
            var apelido = texto.Substring(3).Trim();
            await InvokeAsync(async () => await CarregarMesaParaCheckout(apelido: apelido));
            return [];
        }

        var result = await ProdutoService.GetProdutosPorPaginaAsync(1, 10, texto, null, ocultaDoGestorSophos: true);
        if (ct.IsCancellationRequested) return [];

        var produtos = result.Data.Where(x => x.Ativo).ToList();

        // Código de barras / código interno exato → seleciona diretamente
        var exactMatch = produtos.FirstOrDefault(p => p.CodBarras == texto || p.CodigoInterno == texto);
        if (exactMatch is not null)
        {
            await InvokeAsync(async () => await SelecionarProduto(exactMatch));
            return [];
        }

        return produtos;
    }

    private async Task OnKeyDownAutocomplete(KeyboardEventArgs e)
    {
        if (e.Key.StartsWith("F") && e.Key.Length > 1)
        {
            await HandleGlobalKeyDown(e);
            return;
        }

        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_pesquisaAtual))
        {
            var texto = _pesquisaAtual.Trim();

            if (texto.StartsWith("ca*", StringComparison.OrdinalIgnoreCase))
            {
                var apelido = texto.Substring(3).Trim();
                if (!string.IsNullOrWhiteSpace(apelido))
                {
                    await CarregarMesaParaCheckout(apelido: apelido);
                    return;
                }
            }

            if (texto.StartsWith("c*", StringComparison.OrdinalIgnoreCase))
            {
                var numStr = texto.Substring(2).Trim();
                if (int.TryParse(numStr, out int codExterno))
                {
                    await CarregarMesaParaCheckout(codExterno: codExterno);
                    return;
                }
            }
        }
    }

    private async Task OnProdutoSelecionado(ClsProduto? produto)
    {
        if (produto is null) return;
        await SelecionarProduto(produto);
    }

    // ── Lógica de carrinho ──────────────────────────────────────
    private async Task SelecionarProduto(ClsProduto produto)
    {
        if (!AppState.CaixaAberto)
        {
            Snackbar.Add("Caixa fechado. Abra o caixa para lançar itens.", Severity.Warning);
            await _autocompleteRef.ClearAsync();
            return;
        }

        _itemAtual = produto;
        float preco = produto.Precos.Count > 0 ? produto.Precos.Min(p => p.Valor) : 0f;
        float qtdAdicionado = (float)_quantidade;

        // Lógica de Balança
        if (produto.UltilizaProdutoNaBalanca)
        {
            var peso = new BalancaLeitura { Sucesso = false, Peso = 0 };
            if (AppState.MerchantLogado is not null && AppState.MerchantLogado.UltilizaBalanca)
                peso = await BalancaService.LerPesoAsync();

            if (!peso.Sucesso || peso.Peso == 0)
            {
                var optionsDoInput = new DialogOptions { BackdropClick = false, MaxWidth = MaxWidth.ExtraLarge, FullWidth = false, CloseOnEscapeKey = true };
                var dialogInput = await DialogService.ShowAsync<InputFloatN3>("Peso do Item", optionsDoInput);
                var resultInput = await dialogInput.Result;

                if (!resultInput!.Canceled && resultInput.Data is float ValorQtd)
                    qtdAdicionado = ValorQtd;
                else
                    return;
            }
            else
            {
                qtdAdicionado = (float)peso.Peso;
            }
        }

        // Lógica de Venda por Valor
        if (produto.TipoDeVenda == "V")
        {
            var parameters = new DialogParameters { { "Valor", preco } };
            var optionsDoInputValor = new DialogOptions { BackdropClick = false, MaxWidth = MaxWidth.ExtraLarge, FullWidth = false, CloseOnEscapeKey = true };
            var dialogInputValor = await DialogService.ShowAsync<InputFloatN3>("Valor do Item", parameters, optionsDoInputValor);
            var resultInputValor = await dialogInputValor.Result;

            if (!resultInputValor!.Canceled && resultInputValor.Data is float Valor)
            {
                if (preco > 0)
                    qtdAdicionado = (float)Math.Round(Valor / preco, 3);
                preco = (float)Math.Round(Valor, 2);
            }
            else
            {
                return;
            }
        }

        // Lógica de Produto Fracionado (Pizza)
        if (produto.Fracionado)
        {
            List<ClsProduto> produtosFracionados = await ProdutoService.GetProdutosFracionadosAsync();
            produtosFracionados = produtosFracionados.Where(p => p.Id != produto.Id).ToList();
            produto.GruposDeComplementosDoProduto?.RemoveAll(g => g.Grupo.Descricao.StartsWith("Sabor "));
            produto.GruposDeComplementosDoProduto ??= new List<ClsGruposDeComplementosDoProduto>();

            for (var i = (QtdDeSaboresAceitos - 1); i >= 1; i--)
            {
                var novoGrupo = new ClsGruposDeComplementosDoProduto
                {
                    QtdMin = 0,
                    QtdMax = 1,
                    Grupo = new ClsGrupoDeComplemento
                    {
                        Id = i,
                        Descricao = $"Sabor {i + 1}",
                        Ativo = true,
                        Complementos = produtosFracionados.Select((p, idx) => new ClsComplementoDoGrupo
                        {
                            Complemento = new ClsComplemento
                            {
                                Id = idx,
                                Descricao = p.Descricao,
                                ProdutoId = p.Id,
                                Produto = p,
                                EProduto = true,
                                Ativo = true
                            }
                        }).ToList()
                    }
                };
                produto.GruposDeComplementosDoProduto.Insert(0, novoGrupo);
            }

            var paramsFrac = new DialogParameters { { "AtualizandoItem", false }, { "Produto", produto } };
            var optsFrac = new DialogOptions { BackdropClick = true, NoHeader = true, MaxWidth = MaxWidth.ExtraLarge, FullWidth = true, CloseOnEscapeKey = true };
            var dialogFrac = await DialogService.ShowAsync<ModalDeComplementoETamanhoDoItemVenda>("Detalhes do item", paramsFrac, optsFrac);
            var resultFrac = await dialogFrac.Result;

            if (!resultFrac!.Canceled && resultFrac.Data is ItensPedido itemFracionado)
            {
                itemFracionado.Complementos.RemoveAll(c => c.Complemento?.EProduto == true && c.Complemento?.Produto?.Fracionado == true);

                if (_isFechamentoDeMesa)
                {
                    var pedidoMesaFrac = new ClsPedido
                    {
                        TipoDePedido = "MESA",
                        MesaComandaId = _pedido.MesaComandaId,
                        Itens = new List<ItensPedido> { itemFracionado }
                    };
                    _enviando = true;
                    StateHasChanged();
                    try
                    {
                        var response = await PedidosService.CreatePedidoMesa(pedidoMesaFrac);
                        if (response.Status == "success")
                        {
                            Snackbar.Add($"{produto.Descricao} adicionado à mesa.", Severity.Success);
                            var mesaAberta = _mesasAtivas.FirstOrDefault(x => x.Id == _pedido.MesaComandaId);
                            if (mesaAberta != null)
                                await CarregarMesaParaCheckout(mesaAberta.CodigoExterno);
                        }
                        else
                        {
                            Snackbar.Add($"Erro ao adicionar: {string.Join(",", response.Messages)}", Severity.Error);
                        }
                    }
                    finally
                    {
                        _enviando = false;
                        _quantidade = 1;
                        await _autocompleteRef.ClearAsync();
                        StateHasChanged();
                    }
                    return;
                }

                _pedido.Itens.Add(itemFracionado);
                _quantidade = 1;
                await _autocompleteRef.ClearAsync();
                StateHasChanged();
                await _autocompleteRef.FocusAsync();
            }
            else
            {
                Snackbar.Add("Produto com informações obrigatórias não informadas", Severity.Error);
                _itemAtual = null;
                _quantidade = 1;
                await _autocompleteRef.ClearAsync();
                StateHasChanged();
            }
            return;
        }

        // Lógica de Complementos / Tamanhos
        if ((produto.GruposDeComplementosDoProduto is not null && produto.GruposDeComplementosDoProduto.Count > 0) ||
            (!produto.TamanhoUnico && produto.Precos.Count > 0))
        {
            var paramsComp = new DialogParameters { { "AtualizandoItem", false }, { "Produto", produto } };
            var optsComp = new DialogOptions { BackdropClick = true, NoHeader = true, MaxWidth = MaxWidth.ExtraLarge, FullWidth = true, CloseOnEscapeKey = true };
            var dialogComp = await DialogService.ShowAsync<ModalDeComplementoETamanhoDoItemVenda>("Detalhes do item", paramsComp, optsComp);
            var resultComp = await dialogComp.Result;

            if (!resultComp!.Canceled && resultComp.Data is ItensPedido itemComplemento)
            {
                if (_isFechamentoDeMesa)
                {
                    var pedidoMesaComp = new ClsPedido { TipoDePedido = "MESA", MesaComandaId = _pedido.MesaComandaId, Itens = new List<ItensPedido> { itemComplemento } };
                    _enviando = true;
                    StateHasChanged();
                    try
                    {
                        var response = await PedidosService.CreatePedidoMesa(pedidoMesaComp);
                        if (response.Status == "success")
                        {
                            Snackbar.Add($"{produto.Descricao} adicionado à mesa.", Severity.Success);
                            var mesaAberta = _mesasAtivas.FirstOrDefault(x => x.Id == _pedido.MesaComandaId);
                            if (mesaAberta != null)
                                await CarregarMesaParaCheckout(mesaAberta.CodigoExterno);
                        }
                        else
                        {
                            Snackbar.Add($"Erro ao adicionar: {string.Join(",", response.Messages)}", Severity.Error);
                        }
                    }
                    finally
                    {
                        _enviando = false;
                        _quantidade = 1;
                        await _autocompleteRef.ClearAsync();
                        StateHasChanged();
                    }
                    return;
                }

                _pedido.Itens.Add(itemComplemento);
                _quantidade = 1;
                await _autocompleteRef.ClearAsync();
                StateHasChanged();
                await _autocompleteRef.FocusAsync();
            }
            else
            {
                Snackbar.Add("Produto com informações obrigatórias não informadas", Severity.Error);
                _itemAtual = null;
                _quantidade = 1;
                await _autocompleteRef.ClearAsync();
                StateHasChanged();
            }
            return;
        }

        if (_isFechamentoDeMesa)
        {
            float precoTotalCalculado = produto.TipoDeVenda != "V" ? preco * qtdAdicionado : preco;

            var novoItemLocal = new ItensPedido
            {
                Descricao = produto.Descricao,
                Produto = produto,
                Quantidade = qtdAdicionado,
                PrecoUnitario = preco,
                PrecoTotal = precoTotalCalculado
            };

            var pedidoMesaTemp = new ClsPedido
            {
                TipoDePedido = "MESA",
                MesaComandaId = _pedido.MesaComandaId,
                Itens = new List<ItensPedido> { novoItemLocal }
            };

            _enviando = true;
            StateHasChanged();

            try
            {
                var response = await PedidosService.CreatePedidoMesa(pedidoMesaTemp);
                if (response.Status == "success")
                {
                    Snackbar.Add($"{produto.Descricao} adicionado à mesa.", Severity.Success);
                    var mesaAberta = _mesasAtivas.FirstOrDefault(x => x.Id == _pedido.MesaComandaId);
                    if (mesaAberta != null)
                        await CarregarMesaParaCheckout(mesaAberta.CodigoExterno);
                }
                else
                {
                    Snackbar.Add($"Erro ao adicionar: {string.Join(",", response.Messages)}", Severity.Error);
                }
            }
            finally
            {
                _enviando = false;
                _quantidade = 1;
                await _autocompleteRef.ClearAsync();
                StateHasChanged();
            }
            return;
        }

        var existente = _pedido.Itens.FirstOrDefault(x =>
            x.Produto?.Id == produto.Id && x.PrecoUnitario == preco && produto.TipoDeVenda != "V");

        if (existente is not null)
        {
            existente.Quantidade += qtdAdicionado;
            existente.PrecoTotal = existente.PrecoUnitario * existente.Quantidade;
        }
        else
        {
            float precoTotal = produto.TipoDeVenda != "V" ? preco * qtdAdicionado : preco;
            _pedido.Itens.Add(new ItensPedido
            {
                Descricao = produto.Descricao,
                Produto = produto,
                Quantidade = qtdAdicionado,
                PrecoUnitario = preco,
                PrecoTotal = precoTotal
            });
        }

        _quantidade = 1;
        await _autocompleteRef.ClearAsync();
        StateHasChanged();
        await _autocompleteRef.FocusAsync();
