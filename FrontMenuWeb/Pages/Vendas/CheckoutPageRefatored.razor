@rendermode RenderMode.InteractiveWebAssembly
@attribute [Authorize]
@page "/checkout"
@layout CheckoutLayout
@using FrontMenuWeb.Models.Pedidos
@using FrontMenuWeb.Models.Merchant
@using FrontMenuWeb.Components.Modais.ModaisDeVendas
@using FrontMenuWeb.Components.Modais.ModalFiscais
@using FrontMenuWeb.Services.Fiscal
@using FrontMenuWeb.Dtos
@inject ProdutoService ProdutoService
@inject NfService NFService
@inject PedidosService PedidosService
@inject IJSRuntime JS
@inject BalancaService BalancaService
@inject MesasServices MesasService
@inject CaixaEPagamentosService CaixaService
@implements IAsyncDisposable

<PageTitle>Checkout – Sophos</PageTitle>

<div class="checkout-grid" tabindex="0" @onkeydown="HandleGlobalKeyDown" @ref="_pageRef">

    @* ── COLUNA ESQUERDA: busca + lista de itens ── *@
    <div class="checkout-left">

        @* Barra de busca *@
        <div class="search-bar @(_enviando ? "search-bar--loading" : "")">
            <div class="search-bar__icon">
                <MudIcon Icon="@(_isFechamentoDeMesa ? Icons.Material.Outlined.TableRestaurant : Icons.Material.Outlined.Search)" />
            </div>

            @if (_isFechamentoDeMesa)
            {
                <div class="search-bar__mesa">
                    @(_pedido.MesaApelido ?? AppState.MerchantLogado?.LegendaNomeUltilizadoParaPlaced ?? "Mesa") @_pedido.MesaComandaId
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                   Class="search-bar__mesa-close" OnClick="ClearMesa" />
                </div>
            }

            <MudAutocomplete T="ClsProduto"
                             @ref="_autocompleteRef"
                             SearchFunc="BuscarProdutosAutocomplete"
                             ValueChanged="OnProdutoSelecionado"
                             ToStringFunc="@(p => p?.Descricao ?? string.Empty)"
                             MinCharacters="1"
                             Clearable="true"
                             Variant="Variant.Text"
                             Margin="Margin.Dense"
                             DisableUnderLine="true"
                             Class="search-bar__input"
                             Placeholder="@(_isFechamentoDeMesa ? $"Adicionar item à mesa…" : "Pesquisa item · código · código de barras")"
                             OnKeyDown="OnKeyDownAutocomplete"
                             MaxItems="10"
                             AutoFocus="true">
                <ItemTemplate>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.caption" Color="Color.Primary" Style="min-width:52px; font-weight:bold;">@context.CodigoInterno</MudText>
                        <MudText Typo="Typo.body2" Style="flex:1;">@context.Descricao</MudText>
                        <MudText Typo="Typo.body2" Style="color:#4caf50; font-weight:600; white-space:nowrap;">
                            @(context.Precos.Count > 0 ? context.Precos.Min(x => x.Valor).ToString("C") : "—")
                        </MudText>
                    </MudStack>
                </ItemTemplate>
            </MudAutocomplete>

            <div class="search-bar__hint">
                <code>N*</code> qtd
                @if (!_isFechamentoDeMesa)
                {
                    <span> · <code>c*NN</code> mesa</span>
                }
                @if (_quantidade > 1)
                {
                    <span class="search-bar__hint-emph"> · próx × @_quantidade</span>
                }
            </div>
        </div>

        @* Barra de seleção (aparece quando há itens selecionados) *@
        @if (_itensSelecionados.Count > 0)
        {
            <div class="selection-bar">
                <span class="selection-bar__count">
                    <strong>@_itensSelecionados.Count</strong> selecionado@(_itensSelecionados.Count > 1 ? "s" : "")
                </span>
                <span class="selection-bar__sum">
                    Soma: <strong>@SelectedSum.ToString("C")</strong>
                </span>
                <MudButton Variant="Variant.Text" Size="Size.Small"
                           OnClick="@(() => { _itensSelecionados.Clear(); StateHasChanged(); })">
                    Limpar
                </MudButton>
            </div>
        }

        @* Tabela de itens *@
        <div class="items">
            <div class="items__header">
                <div>Nº</div>
                <div>Descrição</div>
                <div class="items__col-qty">Qtd</div>
                <div class="items__col-val">Valor</div>
                <div></div>
            </div>

            <div class="items__list @(_pedido.Itens.Any() ? "items__list--has-rows" : "")">
                <div class="items__watermark">
                    <img src="/CaixaAberto.png" alt="" />
                </div>

                @if (!_pedido.Itens.Any())
                {
                    <div class="empty">
                        <MudIcon Icon="@Icons.Material.Outlined.ShoppingCart" Style="font-size:56px; opacity:0.5;" />
                        <div class="empty__title">Pedido vazio</div>
                        <div class="empty__hint">
                            Pesquise por <code>código</code> ou <code>nome</code>
                        </div>
                    </div>
                }

                @foreach (var (item, idx) in _pedido.Itens.Select((it, i) => (it, i)))
                {
                    var isSel = _itensSelecionados.Contains(item);
                    var isExp = _itemExpandido.Contains(item);
                    var temObs = !string.IsNullOrWhiteSpace(item.Observacoes);
                    var temNome = !string.IsNullOrWhiteSpace(item.NomeCliente);

                    <div class="@($"row {(isSel ? "row--selected" : "")}")"
                         @onclick="() => ToggleSelecaoItem(item)">
                        <div class="row__num">@($"{idx + 1:00}")</div>
                        <div class="row__main">
                            <div class="row__title">@item.Descricao</div>
                            @if (temObs || temNome)
                            {
                                <div class="row__meta">
                                    @if (temObs)
                                    {
                                        <span class="row__obs">@item.Observacoes</span>
                                    }
                                    @if (temNome)
                                    {
                                        <span class="row__client">
                                            <MudIcon Icon="@Icons.Material.Outlined.Person" Style="font-size:12px;" />
                                            @item.NomeCliente
                                        </span>
                                    }
                                </div>
                            }
                        </div>
                        <div class="row__qty">@item.Quantidade.ToString("0.###")×</div>
                        <div class="row__price">@item.PrecoTotal.ToString("C")</div>
                        <MudIconButton Icon="@(isExp ? Icons.Material.Outlined.ExpandLess : Icons.Material.Outlined.EditNote)"
                                       Size="Size.Small" Class="row__more"
                                       Style="@($"opacity:{(isExp || temObs || temNome || item.Complementos.Count > 0 ? "1" : "0.3")};")"
                                       OnClick="@(async () => await EditarItem(item))" />

                        @if (isExp)
                        {
                            <div class="row__expanded" @onclick:stopPropagation="true">
                                <MudTextField @bind-Value="item.Observacoes"
                                              Placeholder="Observações (ex: sem cebola...)"
                                              Variant="Variant.Outlined" Margin="Margin.Dense"
                                              FullWidth="true"
                                              Adornment="Adornment.Start"
                                              AdornmentIcon="@Icons.Material.Outlined.ChatBubbleOutline" />
                                @if (_isFechamentoDeMesa)
                                {
                                    <MudTextField @bind-Value="item.NomeCliente"
                                                  Placeholder="Nome do cliente"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  FullWidth="true"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Outlined.Person" />
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    @* ── COLUNA DIREITA: totais + opções + ações ── *@
    <div class="checkout-right">

        @* Card de totais hero *@
        <div class="totals">
            <div class="totals__label">@(TemExtras ? "Total Geral" : "Sub Total")</div>
            <div class="totals__amount">
                <span class="totals__currency">R$</span>@TotalIntPart<span class="totals__decimal">,@TotalDecPart</span>
            </div>
            <div class="totals__count">
                <span class="totals__pill">@_pedido.Itens.Count</span>
                @(_pedido.Itens.Count == 1 ? "item" : "itens") no pedido
            </div>

            @if (TemExtras)
            {
                <div class="totals__breakdown">
                    <div class="totals__line">
                        <span>Subtotal</span><span>@SubTotalItens.ToString("C")</span>
                    </div>
                    @if (TaxaValor > 0)
                    {
                        <div class="totals__line totals__line--add">
                            <span>Taxa de serviço (@TaxaPercent%)</span><span>+ @TaxaValor.ToString("C")</span>
                        </div>
                    }
                    @if (CouvertValor > 0)
                    {
                        <div class="totals__line totals__line--couvert">
                            <span>Couvert · @_qtdPessoas pessoa@(_qtdPessoas > 1 ? "s" : "")</span>
                            <span>+ @CouvertValor.ToString("C")</span>
                        </div>
                    }
                </div>
            }
        </div>

        @* Opções de fechamento de mesa *@
        @if (_isFechamentoDeMesa)
        {
            <div class="options">
                <div class="options__title">
                    <MudIcon Icon="@Icons.Material.Outlined.TableRestaurant" Size="Size.Small" Class="mr-1" />
                    Opções de Fechamento
                </div>

                @if ((AppState.MerchantLogado?.TaxaDeServicoPercent ?? 0) > 0)
                {
                    <div class="options__row">
                        <span>Taxa de serviço (@(AppState.MerchantLogado!.TaxaDeServicoPercent)%)</span>
                        <MudSwitch @bind-Value="_cobraTaxa" Color="Color.Primary" Size="Size.Small" />
                    </div>
                }

                @if ((AppState.MerchantLogado?.ValorCouvert ?? 0) > 0)
                {
                    <div class="options__row">
                        <span>Couvert (@(AppState.MerchantLogado!.ValorCouvert?.ToString("C"))/pessoa)</span>
                        <MudSwitch @bind-Value="_cobraCouvert" Color="Color.Secondary" Size="Size.Small" />
                    </div>
                }

                @if (_cobraCouvert)
                {
                    <div class="options__row">
                        <span>Qtd. pessoas</span>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small" Variant="Variant.Outlined"
                                           OnClick="@(() => _qtdPessoas = Math.Max(1, _qtdPessoas - 1))" />
                            <MudText Typo="Typo.body1" Style="min-width:24px; text-align:center;">@_qtdPessoas</MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" Variant="Variant.Outlined"
                                           OnClick="@(() => _qtdPessoas++)" />
                        </MudStack>
                    </div>
                }

                <div class="options__row">
                    <span>Separar por cliente</span>
                    <MudSwitch @bind-Value="_separarPorCliente" Color="Color.Info" Size="Size.Small" />
                </div>
            </div>
        }

        @* Botões de ação *@
        <div class="actions">
            @if (_isFechamentoDeMesa && AppState.MerchantLogado?.AvisaFechamentoDeMesa == true)
            {
                <MudButton Class="action-btn action-btn--warning" Variant="Variant.Filled" FullWidth="true"
                           Disabled="@(!_pedido.Itens.Any() || _enviando)"
                           OnClick="AvisarContaDaMesa">
                    <MudIcon Icon="@Icons.Material.Filled.Print" Size="Size.Small" />
                    <span class="action-btn__label">Imprimir Fechamento</span>
                </MudButton>
            }

            @if (_isFechamentoDeMesa)
            {
                <MudButton Class="action-btn action-btn--info" Variant="Variant.Filled" FullWidth="true"
                           Disabled="@(_enviando)"
                           OnClick="TransferirItensDeMesa">
                    <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small" />
                    <span class="action-btn__label">Transferir @(_itensSelecionados.Count > 0 ? $"{_itensSelecionados.Count} item(s)" : "Itens") de @(AppState.MerchantLogado?.LegendaNomeUltilizadoParaPlaced ?? "Mesa")</span>
                </MudButton>
            }

            <MudButton Class="action-btn action-btn--primary" Variant="Variant.Filled" FullWidth="true"
                       Disabled="@(!_pedido.Itens.Any() || _enviando)"
                       OnClick="Finalizar">
                @if (_enviando)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" Class="me-2" />
                    <span class="action-btn__label">Finalizando...</span>
                }
                else
                {
                    <span class="kbd" style="margin-right: 18px;">F1</span>
                    <span class="action-btn__label">Finalizar</span>
                }
            </MudButton>

            @if (_itensSelecionados.Count > 0)
            {
                <MudButton Class="action-btn action-btn--warning" Variant="Variant.Filled" FullWidth="true"
                           Disabled="@_enviando"
                           OnClick="FinalizarParcial">
                    <span class="kbd kbd--dark" style="margin-right: 18px;">F6</span>
                    <span class="action-btn__label">Finalizar Parcial</span>
                </MudButton>
            }

            <MudButton Class="action-btn action-btn--info" Variant="Variant.Filled" FullWidth="true"
                       Disabled="@(!_pedido.Itens.Any() || _enviando)"
                       OnClick="TransferirVenda">
                <span class="kbd" style="margin-right: 18px;">F2</span>
                <span class="action-btn__label">Transferir Venda</span>
            </MudButton>

            <MudButton Class="action-btn action-btn--ghost" Variant="Variant.Filled" FullWidth="true"
                       Disabled="@(!_pedido.Itens.Any())"
                       OnClick="CancelarItem">
                <span class="kbd" style="margin-right: 18px;">F4</span>
                <MudIcon Icon="@Icons.Material.Outlined.Backspace" Size="Size.Small" Style="margin-right: 18px;" />
                <span class="action-btn__label">Cancelar Item</span>
            </MudButton>

            <MudButton Class="action-btn action-btn--danger" Variant="Variant.Filled" FullWidth="true"
                       Disabled="@(!_pedido.Itens.Any() && !_isFechamentoDeMesa)"
                       OnClick="CancelarVenda">
                <span class="kbd" style="margin-right: 18px;">F5</span>
                <span class="action-btn__label">Cancelar Venda</span>
            </MudButton>
        </div>
    </div>

    @if (_emitindoNF)
    {
        <MudOverlay Visible="true" Absolute="true" DarkBackground="true" ZIndex="9999" Class="w-100 h-100">
            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="w-100 h-100" Spacing="3">
                <MudProgressCircular Value="@_progressoNF" Size="Size.Large" Color="Color.Primary" />
                <MudText Typo="Typo.h6" Style="color:#fff;">Emitindo NFC-e...</MudText>
                <MudProgressLinear Value="@_progressoNF" Color="Color.Primary" Style="width:280px;" />
                <MudText Typo="Typo.caption" Style="color:#fff;">@_progressoNF%</MudText>
            </MudStack>
        </MudOverlay>
    }
</div>

<style>
    .checkout-grid {
        --orange: #FF7A1A;
        --orange-soft: rgba(255, 122, 26, 0.12);
        --bg: #1A2538;
        --bg-deep: #131C2C;
        --surface: #232F45;
        --surface-2: #2C3A53;
        --line: rgba(255, 255, 255, 0.08);
        --fg: #F5F7FA;
        --fg-2: #B7C0CC;
        --fg-3: #7E8A9C;
        --success: #4CAF50;
        --warning: #FFC107;
        --info: #2196F3;
        --danger: #F44336;
        --couvert: #A78BFA;

        position: relative;
        height: calc(100vh - 56px);
        display: grid;
        grid-template-columns: 75% 25%;
        gap: 16px;
        padding: 16px;
        background: var(--bg);
        outline: none;
        overflow: hidden;
    }


    /* ── Search bar ── */
    .search-bar {
        display: flex;
        align-items: center;
        gap: 12px;
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 8px;
        flex-shrink: 0;
        transition: border-color 150ms, box-shadow 150ms;
    }
    .search-bar:focus-within {
        border-color: var(--orange);
        box-shadow: 0 0 0 3px var(--orange-soft);
    }
    .search-bar--loading { opacity: 0.6; pointer-events: none; }
    .search-bar__icon {
        width: 44px; height: 44px;
        display: grid; place-items: center;
        background: var(--orange-soft);
        color: var(--orange);
        border-radius: 8px;
        flex-shrink: 0;
    }
    .search-bar__mesa {
        display: inline-flex; align-items: center; gap: 6px;
        background: var(--orange);
        color: #fff; font-weight: 700; font-size: 13px;
        padding: 6px 6px 6px 12px;
        border-radius: 999px;
        flex-shrink: 0;
        white-space: nowrap;
    }
    .search-bar__mesa-close.mud-icon-button {
        color: #fff !important;
        background: rgba(255,255,255,0.22);
        width: 22px; height: 22px;
        padding: 2px;
    }
    .search-bar__input { flex: 1; }
    .search-bar__input .mud-input-slot {
        color: var(--fg) !important;
        font-size: 16px !important;
        background: transparent !important;
    }
    .search-bar__hint {
        color: var(--fg-3); font-size: 12px;
        padding-right: 12px; flex-shrink: 0;
        white-space: nowrap;
    }
    .search-bar__hint code {
        background: var(--bg-deep); color: var(--fg-2);
        padding: 2px 6px; border-radius: 4px;
        font-family: 'Roboto Mono', monospace; font-size: 11px;
    }
    .search-bar__hint-emph { color: var(--orange); font-weight: 600; }

    /* ── Selection bar ── */
    .selection-bar {
        display: flex; align-items: center; gap: 12px;
        background: var(--orange-soft);
        border: 1px solid var(--orange);
        border-radius: 8px;
        padding: 8px 12px 8px 16px;
        flex-shrink: 0;
    }
    .selection-bar__count { color: var(--orange); font-weight: 600; }
    .selection-bar__sum { margin-left: auto; color: var(--fg-2); font-size: 13px; }
    .selection-bar__sum strong { color: var(--fg); font-family: 'Roboto Mono', monospace; }

    /* ── Items table ── */
    .items {
        flex: 1; min-height: 0; overflow: hidden;
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 12px;
        display: flex; flex-direction: column;
        position: relative;
    }
    .items__header {
        display: grid;
        grid-template-columns: 48px 1fr 80px 100px 40px;
        gap: 8px; padding: 10px 16px;
        background: var(--surface-2);
        border-bottom: 1px solid var(--line);
        font-size: 11px; font-weight: 600;
        color: var(--fg-3); letter-spacing: 0.08em;
        text-transform: uppercase;
        flex-shrink: 0;
    }
    .items__col-qty { text-align: center; }
    .items__col-val { text-align: right; }
    .items__list { flex: 1; overflow-y: auto; position: relative; }
    .items__watermark {
        position: absolute; inset: 0;
        display: grid; place-items: center;
        pointer-events: none; z-index: 0;
        overflow: hidden;
    }
    .items__watermark img { width: 100%; height: 100%; object-fit: contain; opacity: 0.06; overflow: hidden; }
    .items__list--has-rows .items__watermark { opacity: 0; }

    .row {
        position: relative; z-index: 1;
        display: grid;
        grid-template-columns: 48px 1fr 80px 100px 40px;
        gap: 8px; align-items: center;
        padding: 12px 16px;
        border-bottom: 1px solid var(--line);
        cursor: pointer;
        color: var(--fg);
        transition: background 80ms;
    }
    .row:hover { background: var(--surface-2); }
    .row--selected {
        background: var(--orange-soft) !important;
        box-shadow: inset 3px 0 0 var(--orange);
    }
    .row__num { text-align: center; font-family: 'Roboto Mono', monospace; font-weight: 600; color: var(--fg-2); }
    .row__main { min-width: 0; }
    .row__title { font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .row__meta { display: flex; gap: 8px; margin-top: 2px; align-items: center; }
    .row__obs { font-size: 12px; color: var(--fg-3); font-style: italic; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 200px; }
    .row__client {
        display: inline-flex; align-items: center; gap: 4px;
        height: 18px; padding: 0 8px; border-radius: 999px;
        background: var(--orange-soft); color: var(--orange);
        font-size: 11px; font-weight: 600; white-space: nowrap;
    }
    .row__qty { text-align: center; font-family: 'Roboto Mono', monospace; font-weight: 600; }
    .row__price { text-align: right; font-family: 'Roboto Mono', monospace; font-weight: 700; color: var(--success); }
    .row__more { color: var(--fg-2) !important; }
    .row__expanded {
        grid-column: 1 / -1;
        display: flex; gap: 8px; padding-top: 8px;
        border-top: 1px solid var(--line);
    }

    /* ── Empty state ── */
    .empty {
        position: absolute; inset: 0; z-index: 1;
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: 8px; color: var(--fg-3);
    }
    .empty__title { font-size: 15px; }
    .empty__hint { font-size: 12px; display: flex; gap: 8px; }
    .empty__hint code {
        background: var(--surface-2); color: var(--fg-2);
        padding: 3px 8px; border-radius: 4px;
        font-family: 'Roboto Mono', monospace; font-size: 11px;
    }

    /* ── Right column ── */
    .checkout-right {
        display: flex; 
        flex-direction: column; 
        gap: 12px;
        min-height: 0; overflow-y: auto;
    }

    /* ── Left column ── */
    .checkout-left {
        display: flex;
        flex-direction: column;
        gap: 12px;
        min-height: 0;
        overflow: hidden;
    }

    /* ── Totals hero ── */
    .totals {
        background: linear-gradient(155deg, var(--surface) 0%, var(--surface-2) 100%);
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 24px;
        position: relative; overflow: hidden;
        flex-shrink: 0;
    }
    .totals::before {
        content: ''; position: absolute; inset: 0; pointer-events: none;
        background: radial-gradient(120% 80% at 100% 0%, rgba(255,122,26,0.08) 0%, transparent 60%);
    }
    .totals__label { font-size: 11px; letter-spacing: 0.16em; color: var(--fg-3); text-transform: uppercase; font-weight: 600; position: relative; }
    .totals__amount {
        font-size: 48px; font-weight: 700; line-height: 1.05;
        margin-top: 4px; color: var(--fg);
        font-variant-numeric: tabular-nums; letter-spacing: -0.02em;
        position: relative;
    }
    .totals__currency { font-size: 22px; font-weight: 500; color: var(--fg-2); margin-right: 6px; vertical-align: 6px; }
    .totals__decimal { font-size: 28px; }
    .totals__count { font-size: 13px; color: var(--fg-2); margin-top: 6px; position: relative; }
    .totals__pill {
        display: inline-flex; padding: 2px 10px; border-radius: 999px;
        background: var(--orange-soft); color: var(--orange);
        font-weight: 600; font-size: 11px;
    }
    .totals__breakdown {
        margin-top: 16px; padding-top: 12px;
        border-top: 1px dashed var(--line);
        display: flex; flex-direction: column; gap: 6px;
        position: relative;
    }
    .totals__line { display: flex; justify-content: space-between; font-size: 12px; }
    .totals__line span:first-child { color: var(--fg-3); }
    .totals__line span:last-child { font-family: 'Roboto Mono', monospace; font-weight: 600; color: var(--fg); }
