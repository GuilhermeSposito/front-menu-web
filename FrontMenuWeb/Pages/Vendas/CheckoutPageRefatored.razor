    private decimal CouvertPorPessoa => (decimal)(AppState.MerchantLogado?.ValorCouvert ?? 0);
    private decimal CouvertValor => _isFechamentoDeMesa && _cobraCouvert ? CouvertPorPessoa * _qtdPessoas : 0m;
    private decimal TotalGeral => SubTotalItens + TaxaValor + CouvertValor;
    private bool TemExtras => TaxaValor > 0 || CouvertValor > 0;
    private decimal SelectedSum => _itensSelecionados.Sum(i => (decimal)i.PrecoTotal);
