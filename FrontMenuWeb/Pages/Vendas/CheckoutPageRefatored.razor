    private async Task CarregarMesaParaCheckout(int? codExterno = null, string? apelido = null)
    {
        ClsMesasEComandas? mesa = null;
        if (codExterno.HasValue)
            mesa = _mesasAtivas.FirstOrDefault(x => x.CodigoExterno == codExterno.Value);
        else if (!string.IsNullOrEmpty(apelido))
            mesa = _mesasAtivas.FirstOrDefault(x => x.apelido?.Equals(apelido, StringComparison.OrdinalIgnoreCase) ?? false);

        if (mesa == null)
        {
            Snackbar.Add($"{AppState.MerchantLogado?.LegendaNomeUltilizadoParaPlaced} {(codExterno?.ToString() ?? apelido)} não encontrada.", Severity.Warning);
            await _autocompleteRef.ClearAsync();
            return;
        }

        var nomeMesa = $"{AppState.MerchantLogado?.LegendaNomeUltilizadoParaPlaced} {(codExterno?.ToString() ?? mesa.apelido ?? mesa.Id.ToString())}";
        try
        {
            var result = await PedidosService.GetMesaOcupada(mesa.Id);
            if (result?.Status == "success" && result.Data?.Objeto?.Itens?.Any() == true)
            {
                _pedido = new ClsPedido
                {
                    TipoDePedido = "MESA",
                    MesaComandaId = mesa.Id,
                    MesaApelido = mesa.apelido,
                    Itens = result.Data.Objeto.Itens,
                    CriadoPor = "SOPHOS"
                };
                _isFechamentoDeMesa = true;
                _cobraTaxa = (AppState.MerchantLogado?.TaxaDeServicoPercent ?? 0) > 0;
                _cobraCouvert = (AppState.MerchantLogado?.ValorCouvert ?? 0) > 0;
                _qtdPessoas = 1;
                _separarPorCliente = true;
                _itemAtual = null;
                _itensSelecionados.Clear();
                _itemExpandido.Clear();
                Snackbar.Add($"{nomeMesa} pronta para fechamento.", Severity.Success);
            }
            else
            {
                Snackbar.Add($"{nomeMesa} não possui itens.", Severity.Info);
            }
        }
        catch
        {
            Snackbar.Add($"{nomeMesa} não possui itens.", Severity.Info);
        }

        await _autocompleteRef.ClearAsync();
        StateHasChanged();
        await _autocompleteRef.FocusAsync();
    }

    private void ClearMesa()
    {
        _pedido = new ClsPedido { TipoDePedido = "BALCÃO", CriadoPor = "SOPHOS", EtapaPedido = "FINALIZADO" };
        _isFechamentoDeMesa = false;
        _cobraTaxa = false;
        _cobraCouvert = false;
        _qtdPessoas = 1;
        _separarPorCliente = true;
        _itensSelecionados.Clear();
        _itemExpandido.Clear();
        Snackbar.Add("Mesa liberada.", Severity.Info);
        StateHasChanged();
    }

    // ── Row interactions ───────────────────────────────────────
    private void ToggleSelecaoItem(ItensPedido item)
    {
        if (_itensSelecionados.Contains(item)) _itensSelecionados.Remove(item);
        else _itensSelecionados.Add(item);
        StateHasChanged();
    }

    private void ToggleExpandirItem(ItensPedido item)
    {
        if (_itemExpandido.Contains(item)) _itemExpandido.Remove(item);
        else _itemExpandido.Add(item);
        StateHasChanged();
    }

    // ── Global shortcuts ───────────────────────────────────────
    private async Task HandleGlobalKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "F1": await Finalizar(); break;
            case "F2": await TransferirVenda(); break;
            case "F4": await CancelarItem(); break;
            case "F5": await CancelarVenda(); break;
            case "F6": await FinalizarParcial(); break;
        }
    }

    // ── Actions ────────────────────────────────────────────────
    private async Task AvisarContaDaMesa()
    {
        if (AppState.MerchantLogado?.AvisaFechamentoDeMesa != true || _pedido.MesaComandaId == 0) return;
        var itensParaAviso = _itensSelecionados.Count > 0 ? _itensSelecionados.ToList() : _pedido.Itens;
        await PedidosService.AvisarConta(itensParaAviso, _pedido.MesaComandaId, _cobraTaxa, _cobraCouvert, _cobraCouvert ? _qtdPessoas : null, _separarPorCliente);
        Snackbar.Add("Aviso de fechamento enviado.", Severity.Success);
    }

    private async Task Finalizar()
    {
        if (_pedido.Itens.Count == 0) { Snackbar.Add("Adicione itens à venda.", Severity.Warning); return; }
        if (_enviando || _modalAberto) return;

        _modalAberto = true;
        try
        {
            if (!await AuthorizationService.ValidateAsync("AcessoLancaVenda"))
            {
                Snackbar.Add("Sem permissão: AcessoLancaVenda", Severity.Error);
                return;
            }

            var parameters = new DialogParameters { { "Pedido", _pedido } };
            var options = new DialogOptions { Position = DialogPosition.Center, CloseButton = true, MaxWidth = MaxWidth.False, FullWidth = true, CloseOnEscapeKey = true };
            var dialog = await DialogService.ShowAsync<ModalDePagamento>("Pagamento", parameters, options);
            var result = await dialog.Result;

            if (!result!.Canceled && result.Data is bool sucesso && sucesso)
                await Submit();
        }
        finally { _modalAberto = false; }
    }

    private async Task Submit()
    {
        _enviando = true;
        StateHasChanged();
        try
        {
            ReturnApiRefatored<ClsPedido> response;
            if (_isFechamentoDeMesa)
                response = await PedidosService.FechaMesa(_pedido);
            else
                response = await PedidosService.CreatePedido(_pedido);

            var msg = string.Join(", ", response.Status == "success" ? response.Data.Messages : response.Messages);
            Snackbar.Add(msg, response.Status == "success" ? Severity.Success : Severity.Error);

            if (response.Status == "success")
            {
                if (response.Data.Objeto is not null)
                {
                    bool imprimir = true;
                    if (AppState.MerchantLogado != null && AppState.MerchantLogado.PerguntaImpressaPdv)
                        imprimir = await PerguntaSeImprime();

                    if (imprimir)
                    {
                        await JS.InvokeVoidAsync("baixarJSON", response.Data.Objeto, $"pedido{response.Data.Objeto.DisplayId}-SOPHOS-WEB.json");
                        await PedidosService.UpdatePedidoImpresso(response.Data.Objeto);
                    }

                    if (AppState.MerchantLogado?.EmiteNfAutomatica == true)
                        await EmiteNFCeAutomatico(response.Data.Objeto);
                }

                _pedido = new ClsPedido { TipoDePedido = "BALCÃO", CriadoPor = "SOPHOS", EtapaPedido = "FINALIZADO" };
                _isFechamentoDeMesa = false;
                _itemAtual = null;
                _itensSelecionados.Clear();
                _itemExpandido.Clear();
            }
        }
        finally
        {
            _enviando = false;
            StateHasChanged();
            await _autocompleteRef.FocusAsync();
        }
    }

    private async Task TransferirItensDeMesa()
    {
        if (_enviando || _modalAberto) return;

        var itensParaTransferir = _itensSelecionados.Count > 0
            ? _itensSelecionados.ToList()
            : _pedido.Itens.ToList();

        if (itensParaTransferir.Count == 0) { Snackbar.Add("Nenhum item para transferir.", Severity.Warning); return; }

        var itemIds = itensParaTransferir.Where(i => i.Id > 0).Select(i => i.Id).ToList();
        if (itemIds.Count == 0) { Snackbar.Add("Os itens precisam ter sido salvos para serem transferidos.", Severity.Warning); return; }

        _modalAberto = true;
        try
        {
            var legenda = AppState.MerchantLogado?.LegendaNomeUltilizadoParaPlaced ?? "Mesa";
            var options = new DialogOptions { BackdropClick = false, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true, CloseOnEscapeKey = true };
            var dialog = await DialogService.ShowAsync<InputMesaTransfer>($"Transferir para qual {legenda}?", options);
            var result = await dialog.Result;

            if (result!.Canceled || result.Data is not string valor || string.IsNullOrWhiteSpace(valor)) return;

            ClsMesasEComandas? mesaDestino = null;
            if (int.TryParse(valor, out int codExterno))
                mesaDestino = _mesasAtivas.FirstOrDefault(m => m.CodigoExterno == codExterno);
            else
                mesaDestino = _mesasAtivas.FirstOrDefault(m => m.apelido?.Equals(valor, StringComparison.OrdinalIgnoreCase) ?? false);

            if (mesaDestino == null)
            {
                Snackbar.Add($"{legenda} \"" + valor + "\" não encontrada.", Severity.Warning);
                return;
            }

            if (mesaDestino.Id == _pedido.MesaComandaId)
            {
                Snackbar.Add($"A {legenda} de destino é a mesma que a de origem.", Severity.Warning);
                return;
            }

            _enviando = true;
            StateHasChanged();
            try
            {
                var response = await PedidosService.TransferirItensDeMesa(_pedido.MesaComandaId, mesaDestino.Id, itemIds);
                var msg = string.Join(", ", response.Status == "success" ? response.Data.Messages : response.Messages);
                Snackbar.Add(msg, response.Status == "success" ? Severity.Success : Severity.Error);

                if (response.Status == "success")
                {
                    _itensSelecionados.Clear();
                    var mesaOrigem = _mesasAtivas.FirstOrDefault(m => m.Id == _pedido.MesaComandaId);
                    if (mesaOrigem != null)
                        await CarregarMesaParaCheckout(mesaOrigem.CodigoExterno);
                    else
                        ClearMesa();
                }
            }
            catch (Exception ex) { Snackbar.Add($"Erro na transferência: {ex.Message}", Severity.Error); }
            finally
            {
                _enviando = false;
                StateHasChanged();
                await _autocompleteRef.FocusAsync();
            }
        }
        finally { _modalAberto = false; }
    }

    private async Task TransferirVenda()
    {
        if (_pedido.Itens.Count == 0) { Snackbar.Add("Adicione itens para transferir.", Severity.Warning); return; }
        if (_enviando || _modalAberto) return;

        _modalAberto = true;
        try
        {
            var options = new DialogOptions { BackdropClick = false, MaxWidth = MaxWidth.Large, FullWidth = false, CloseOnEscapeKey = true };
            var label = $"Número da {(AppState.MerchantLogado?.LegendaNomeUltilizadoParaPlaced ?? "Mesa/Comanda")}";
            var dialog = await DialogService.ShowAsync<InputMesaTransfer>(label, options);
            var result = await dialog.Result;

            if (!result!.Canceled && result.Data is string valor && !string.IsNullOrEmpty(valor))
            {
                _enviando = true;
                StateHasChanged();
                try
                {
                    _pedido.TipoDePedido = "MESA";
                    if (int.TryParse(valor, out int numero))
                    {
                        var mesa = _mesasAtivas.FirstOrDefault(m => m.CodigoExterno == numero);
                        _pedido.MesaComandaId = mesa?.Id ?? numero;
                        _pedido.MesaApelido = null;
                    }
                    else
                    {
                        _pedido.MesaComandaId = 0;
                        _pedido.MesaApelido = valor;
                    }

                    var response = await PedidosService.CreatePedidoMesa(_pedido);
                    if (response.Status == "success")
                    {
                        Snackbar.Add(string.Join(", ", response.Data.Messages), Severity.Success);
                        _pedido = new ClsPedido { TipoDePedido = "BALCÃO", CriadoPor = "SOPHOS", EtapaPedido = "FINALIZADO" };
                        _itemAtual = null;
                        _itensSelecionados.Clear();
                        _itemExpandido.Clear();
                    }
                    else
                    {
                        Snackbar.Add(string.Join(", ", response.Messages), Severity.Error);
                    }
                }
                catch (Exception ex) { Snackbar.Add($"Erro na transferência: {ex.Message}", Severity.Error); }
                finally
                {
                    _enviando = false;
                    StateHasChanged();
                    await _autocompleteRef.FocusAsync();
                }
            }
        }
        finally { _modalAberto = false; }
    }

    private async Task CancelarItem()
    {
        if (_pedido.Itens.Count == 0) return;
        if (!await AuthorizationService.ValidateAsync("AcessoCancelaItensDaVenda")) return;

        var confirmacao = await DialogService.ShowMessageBox(
            "Cancelar Item",
            _itensSelecionados.Any() ? "Deseja remover os itens selecionados?" : "Deseja remover o último item?",
            yesText: "Sim, remover", noText: "Cancelar");
        if (confirmacao != true) return;

        if (_itensSelecionados.Any())
        {
            foreach (var item in _itensSelecionados.ToList())
                _pedido.Itens.Remove(item);
            _itensSelecionados.Clear();
            _itemExpandido.Clear();
            Snackbar.Add("Itens selecionados removidos.", Severity.Info);
        }
        else
        {
            _pedido.Itens.Remove(_pedido.Itens.Last());
            Snackbar.Add("Último item removido.", Severity.Info);
        }

        StateHasChanged();
        await _autocompleteRef.FocusAsync();
    }

    private async Task CancelarVenda()
    {
        if (_pedido.Itens.Count == 0 && !_isFechamentoDeMesa) return;
        if (!await AuthorizationService.ValidateAsync("AcessoCancelaItensDaVenda")) return;

        var confirmacao = await DialogService.ShowMessageBox(
            "Cancelar Venda",
            "Deseja realmente cancelar toda a venda?",
            yesText: "Sim, cancelar", noText: "Voltar");
        if (confirmacao != true) return;

        _pedido = new ClsPedido { TipoDePedido = "BALCÃO", CriadoPor = "SOPHOS", EtapaPedido = "FINALIZADO" };
        _isFechamentoDeMesa = false;
        _cobraTaxa = false;
        _cobraCouvert = false;
        _qtdPessoas = 1;
        _separarPorCliente = true;
        _itemAtual = null;
        _itensSelecionados.Clear();
        _itemExpandido.Clear();
        Snackbar.Add("Venda cancelada.", Severity.Warning);
        StateHasChanged();
        await _autocompleteRef.FocusAsync();
    }

    private async Task FinalizarParcial()
    {
        if (_itensSelecionados.Count == 0) { Snackbar.Add("Selecione os itens para pagamento parcial.", Severity.Warning); return; }
        if (_enviando || _modalAberto) return;

        _modalAberto = true;
        try
        {
            if (!await AuthorizationService.ValidateAsync("AcessoLancaVenda"))
            {
                Snackbar.Add("Sem permissão: AcessoLancaVenda", Severity.Error);
                return;
            }

            var subPedido = new ClsPedido
            {
                TipoDePedido = "BALCÃO",
                CriadoPor = "SOPHOS",
                EtapaPedido = "FINALIZADO",
                Itens = _itensSelecionados.ToList()
            };

            var parameters = new DialogParameters { { "Pedido", subPedido } };
            var options = new DialogOptions { Position = DialogPosition.Center, CloseButton = true, MaxWidth = MaxWidth.False, FullWidth = true, CloseOnEscapeKey = true };
            var dialog = await DialogService.ShowAsync<ModalDePagamento>("Pagamento Parcial", parameters, options);
            var result = await dialog.Result;

            if (!result!.Canceled && result.Data is bool sucesso && sucesso)
                await SubmitParcial(subPedido);
        }
        finally { _modalAberto = false; }
    }

    private async Task SubmitParcial(ClsPedido subPedido)
    {
        _enviando = true;
        StateHasChanged();
        try
        {
            ReturnApiRefatored<ClsPedido> response;
            if (_isFechamentoDeMesa)
            {
                subPedido.TipoDePedido = "MESA";
                subPedido.MesaComandaId = _pedido.MesaComandaId;
                subPedido.ItensFechamentoIds = _itensSelecionados.Where(x => x.Id > 0).Select(x => x.Id).ToList();
                response = await PedidosService.FechaMesa(subPedido);
            }
            else
            {
                response = await PedidosService.CreatePedido(subPedido);
            }

            var msg = string.Join(", ", response.Status == "success" ? response.Data.Messages : response.Messages);
            Snackbar.Add("Parcial: " + msg, response.Status == "success" ? Severity.Success : Severity.Error);

            if (response.Status == "success")
            {
                if (response.Data.Objeto is not null)
                {
                    bool imprimir = true;
                    if (AppState.MerchantLogado != null && AppState.MerchantLogado.PerguntaImpressaPdv)
                        imprimir = await PerguntaSeImprime();

                    if (imprimir)
                    {
                        await JS.InvokeVoidAsync("baixarJSON", response.Data.Objeto, $"pedido{response.Data.Objeto.DisplayId}-SOPHOS-WEB.json");
                        await PedidosService.UpdatePedidoImpresso(response.Data.Objeto);
                    }

                    if (AppState.MerchantLogado?.EmiteNfAutomatica == true)
                        await EmiteNFCeAutomatico(response.Data.Objeto);
                }

                foreach (var item in subPedido.Itens)
                    _pedido.Itens.Remove(item);
                _itensSelecionados.Clear();
                _itemExpandido.Clear();

                if (_pedido.Itens.Count == 0)
                {
                    _pedido = new ClsPedido { TipoDePedido = "BALCÃO", CriadoPor = "SOPHOS", EtapaPedido = "FINALIZADO" };
                    _isFechamentoDeMesa = false;
                }
            }
        }
        finally
        {
            _enviando = false;
            StateHasChanged();
            await _autocompleteRef.FocusAsync();
        }
    }

    private async Task<bool> PerguntaSeImprime()
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<ModalDePerguntaDeImpressao>("Confirmar Impressão", options);
        var result = await dialog.Result;
        return !result!.Canceled && result.Data is bool sucesso && sucesso;
    }

    private async Task EmiteNFCeAutomatico(ClsPedido pedido)
    {
        var envNFCeDto = new EnNfCeDto { Pedido = pedido };
        var parameters = new DialogParameters<ModalDeCpfNaNota> { { x => x.enNfCeDto, envNFCeDto } };
        var options = new DialogOptions { CloseButton = false, MaxWidth = MaxWidth.ExtraExtraLarge, FullWidth = true, Position = DialogPosition.Center, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<ModalDeCpfNaNota>("Informações Adicionais", parameters, options);
        var result = await dialog.Result;

        if (result!.Canceled) { Snackbar.Add("Emissão de NFC-e cancelada.", Severity.Info); return; }

        _emitindoNF = true;
        _progressoNF = 0;
        _nfProgressCts = new CancellationTokenSource();
        StateHasChanged();

        _ = SimulaProgressoNFAsync(_nfProgressCts.Token);

        try
        {
            var nfResponse = await NFService.GeraNFCe(envNFCeDto);
            var msg = nfResponse.Status == "error"
                ? string.Join(", ", nfResponse.Messages)
                : string.Join(", ", nfResponse.Data?.Messages ?? new List<string>());
            Snackbar.Add(msg, nfResponse.Status == "error" ? Severity.Error : Severity.Success);

            if (nfResponse.Status != "error" && nfResponse.Data?.ObjetoWhenWriting?.XmlStringField is not null)
                await JS.InvokeVoidAsync("baixarXMLNF", nfResponse.Data.ObjetoWhenWriting.XmlStringField, $"{nfResponse.Data.ObjetoWhenWriting.ChaveNf}-procnfe.xml");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao emitir NFC-e: {ex.Message}", Severity.Error);
        }
        finally
        {
            _nfProgressCts?.Cancel();
            _progressoNF = 100;
            StateHasChanged();
            await Task.Delay(300);
            _emitindoNF = false;
            StateHasChanged();
        }
    }

    private async Task SimulaProgressoNFAsync(CancellationToken token)
    {
        while (_progressoNF < 90 && !token.IsCancellationRequested)
        {
            await Task.Delay(120, token).ContinueWith(_ => { });
            _progressoNF = Math.Min(_progressoNF + Random.Shared.Next(2, 6), 90);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task EditarItem(ItensPedido item)
    {
        bool temComplementos = item.Produto?.GruposDeComplementosDoProduto is { Count: > 0 };
        bool temTamanhos = item.Produto is not null && !item.Produto.TamanhoUnico && item.Produto.Precos.Count > 0;

        if (!temComplementos && !temTamanhos)
        {
            ToggleExpandirItem(item);
            return;
        }

        var parameters = new DialogParameters
        {
            { "AtualizandoItem", true },
            { "Produto", item.Produto },
            { "Item", item },
            { "Complementos", item.Complementos }
        };
        var options = new DialogOptions { BackdropClick = false, NoHeader = true, MaxWidth = MaxWidth.ExtraLarge, FullWidth = true, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<ModalDeComplementoETamanhoDoItemVenda>("Detalhes do item", parameters, options);
        var result = await dialog.Result;

        if (!result!.Canceled && result.Data is ItensPedido itemAtualizado)
        {
            var idx = _pedido.Itens.IndexOf(item);
            if (idx >= 0)
                _pedido.Itens[idx] = itemAtualizado;
            Snackbar.Add("Item atualizado.", Severity.Success);
            StateHasChanged();
        }
    }

    public ValueTask DisposeAsync() => ValueTask.CompletedTask;
}
