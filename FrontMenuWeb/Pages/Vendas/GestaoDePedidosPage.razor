    #region Funções de Integrações
    private async Task EnviaMensagemNoWhatsAppDeUpdateDoPedido(ClsPedido Pedido, EtapasPedido etapa)
    {
        if ((Pedido.CriadoPor == "SOPHOS") || (AppState.MerchantLogado.EnviaMsgWhatsIntegracao && Pedido.CriadoPor != "IFOOD")) //Envia para a integração menos ifood
        {
            if (AppState.MerchantLogado is not null && AppState.MerchantLogado.UsaIntegracaoDoWhatsApp)
            {
                if (Pedido.Cliente is null || string.IsNullOrEmpty(Pedido.Cliente.Telefone))
                    return;

                if ((Pedido.TipoDePedido == "DELIVERY" && AppState.MerchantLogado.EnviaMsgWhatsDelivery) || (Pedido.TipoDePedido == "BALCÃO" && AppState.MerchantLogado.EnviaMsgWhatsBalcao))
                    await MessageService.EnviarMensagem(Pedido, etapa);

            }
        }
    }

