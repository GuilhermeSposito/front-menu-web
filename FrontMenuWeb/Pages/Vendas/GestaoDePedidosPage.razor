    #region Funções para Enviar Pedidos para Entrega
    private async Task EnviarParaEntrega(EmpresaMachine EmpresaEnviada, ClsPedido pedido)
    {
        if (EmpresasMachine is not null)
        {
            var parameters = new DialogParameters<ModalDeExcluir>
            {
                { x => x.ContentText, $"Atenção: Ao confirmar você estara enviando o pedido para o mapa da {EmpresaEnviada.Nome}. Deseja continuar?" },
                { x => x.ButtonText, "Sim" },
                { x => x.Color, Color.Error}
            };
            var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Large, CloseOnEscapeKey = true };
            var dialog = await DialogService.ShowAsync<ModalDeExcluir>
                ("Confirmar Envio De Pedido", parameters, options);
            var result = await dialog.Result;

            if (!result!.Canceled && result.Data is bool sucesso && sucesso)
            {
                if (EmpresasMachine.Count == 0)
                {
                    Snackbar.Add("Nenhuma empresa integrada para entrega encontrada. Por favor, configure uma integração de entrega para usar esse recurso.", Severity.Warning);
                    return;
                }

                var empresaSelecionada = EmpresaEnviada;

                Dictionary<string, Severity>
                    Reponse = await MachineService.EnviaPedidoParaOMapa(empresaSelecionada!, pedido, AppState);
                var primeiro = Reponse.First();
                Snackbar.Add(primeiro.Key, primeiro.Value);
            }
        }
    }

    private async Task CarregaEmpresasMachine()
    {
        EmpresasMachine = await EmpresasMachineService.GetEmpresasIntegradas();
    }
