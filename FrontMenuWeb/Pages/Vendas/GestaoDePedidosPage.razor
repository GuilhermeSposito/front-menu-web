    private async Task MudaEtapaDoPedido(ClsDeSuporteParaMostrarPedidos? Supor = null)
    {
        try
        {
            CarregandoParteFiscal = true;
            List<ClsDeSuporteParaMostrarPedidos> ListaDePedidos = new List<ClsDeSuporteParaMostrarPedidos>();

            if (Supor is not null)
            {
                ListaDePedidos.Add(Supor);
                Supor.Selecionado = false;
            }
            else if (ItensSelecionadosPArAProximaEtapa.Count > 0)
            {
                ListaDePedidos.AddRange(ItensSelecionadosPArAProximaEtapa);
                ItensSelecionadosPArAProximaEtapa.Clear();
            }

            await AtualizaPedidosEtapaComProgresso(ListaDePedidos, Supor);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao atualizar etapa do pedido", Severity.Error);
        }


    }


    private async Task AtualizaPedidosEtapaComProgresso(List<ClsDeSuporteParaMostrarPedidos> ListaDePedidos, ClsDeSuporteParaMostrarPedidos? Supor = null)
    {
        try
        {
            LabelDeCarregamento = "Enviando Pedidos para proxima etapa...";
            CarregandoParteFiscal = true;
            ProgressoFiscal = 0;
            await InvokeAsync(StateHasChanged);

            int total = ListaDePedidos.Count;
            int atual = 0;

            foreach (var item in ListaDePedidos)
            {
                atual++;

                if (item.Selector == "NOVO")
                {
                    if (item.Pedido.CriadoPor != "SOPHOS" && item.Pedido.CriadoPor != "SOPHOS CARDAPIO")
                    {
                        var response = await IntegracoesSophosService.AceitaPedido(item.Pedido.IfoodID ?? string.Empty);
                        if (response.Status == "success")
                            ImprimirPedido(item.Pedido, false);
                    }

                    item.Selector = "PREPARANDO";
                    var Response = await PedidosService.UpdatePedidoPreparando(item.Pedido, AppState.MerchantLogado.Id);
                    MostraMensagemDeUpdateDoPedido(Response);

                    EnviaMensagemNoWhatsAppDeUpdateDoPedido(item.Pedido, EtapasPedido.PREPARANDO);
                }
                else if (item.Selector == "PREPARANDO")
                {
                    item.Selector = "DESPACHADO";
                    var Response = await PedidosService.UpdatePedidoDespachadoEPronto(item.Pedido);
                    MostraMensagemDeUpdateDoPedido(Response);
                    EnviaMensagemNoWhatsAppDeUpdateDoPedido(item.Pedido, EtapasPedido.DESPACHADO);
                }
                else if (item.Selector == "DESPACHADO")
                {
                    item.Selector = "FINALIZADO";
                    item.UltimaEtapa = true;
                    var Response = await PedidosService.UpdatePedidoFinalizadoo(item.Pedido);
                    MostraMensagemDeUpdateDoPedido(Response);
                    EnviaMensagemNoWhatsAppDeUpdateDoPedido(item.Pedido, EtapasPedido.FINALIZADO);
                }

                // Atualiza progresso baseado em quantos já foram processados
                ProgressoFiscal = (int)(((double)atual / total) * 100);

                // Se quiser travar em 98% até terminar tudo:
                ProgressoFiscal = Math.Min(ProgressoFiscal, 98);

                await InvokeAsync(StateHasChanged);
            }

            // Finaliza em 100%
            ProgressoFiscal = 100;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao atualizar etapa do pedido", Severity.Error);
        }
        finally
        {
            CarregandoParteFiscal = false;
        }

    }

    private async Task AvisarNovamenteMesmoPedido(ClsPedido pedido)
    {
        var Response = await PedidosService.UpdatePedidoDespachadoEPronto(pedido);
