    private async void VerificaSeTemPedidosAbertos()
    {
        PaginatedResponse<ClsPedido> retornoPedidosAbertos = await PedidosService.GetPedidosPorPaginaAsync(new QuerysDePedidos() { Page = 1, PageSize = 300, Status = StatusPedidos.ABERTO });
        if (retornoPedidosAbertos.Total > 0)
        {
            bool TemPedidoAbertoIntegracao = false;
            foreach (var pedido in retornoPedidosAbertos.Data)
            {
                if (pedido.CriadoPor != "SOPHOS")
                {
                    TemPedidoAbertoIntegracao = true;
                    break;
                }
            }

            if (TemPedidoAbertoIntegracao)
            {
                await JS.InvokeVoidAsync("playNotificationSoundPedidoIntegracao");
                Snackbar.Add("Você tem um pedido aguardando aceite!", Severity.Warning);
                return;
            }

        }

        PaginatedResponse<ClsPedido> RetornoPedidosAgendados = await PedidosService.GetPedidosPorPaginaAsync(new QuerysDePedidos() { Page = 1, PageSize = 300, Agendado = true, Imprimiu = false });
        if (RetornoPedidosAgendados.Data.Count() > 0)
        {
            DateTime HorarioAtual = DateTime.Now.AddHours(-3); //Pra ser o utc igual o nosso
            foreach (var Pedido in RetornoPedidosAgendados.Data)
            {
                if (Pedido.PedidoAgendado && Pedido.HorarioDataAgendamento is not null)
                    if (Pedido.HorarioDataAgendamento.Value.AddMinutes(-AppState.MerchantLogado.TempoDePreparacaoEmMin) <= HorarioAtual)
                    {
                        Snackbar.Add($"O pedido {Pedido.DisplayId} foi impresso automaticamente por ser um pedido agendado próximo do horário de preparo!", Severity.Info);
                        await JS.InvokeVoidAsync("playNotificationSoundPedidoIntegracao");
                        await ImprimirPedido(Pedido, false);
                        await PedidosService.UpdatePedidoImpresso(Pedido);
                    }
            }
        }
    }

