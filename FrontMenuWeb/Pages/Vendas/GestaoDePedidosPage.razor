    private async Task IniciarTimer()
    {
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(30));

        while (await _timer.WaitForNextTickAsync(_cts.Token))
        {
            VerificaSeTemPedidosAbertos();
            await VerificaPedidosNaoImpressos();
        }
    }

    private async Task VerificaPedidosNaoImpressos()
    {
        try
        {
            if (ProcessandoNovoPedido) //condicional para não duplicar a impressão
                return;

            bool IntegraIfood = await LocalStorage.GetItemAsync<bool?>("IntegraIfood") ?? false;
            if (!IntegraIfood)
            {
                _cts.Cancel();
                return;
            }

            var result = await PedidosService.GetPedidosPorPaginaAsync(new QuerysDePedidos() { PageSize = 10, Pesquisa = pesquisaTexto, TipoPedido = FiltroPorTipoDePedido, Imprimiu = false });

            if (result?.Data?.Any() == true)
            {
                List<ClsPedido> pedidosNaoImpressos = result.Data.Where(p => !p.Imprimiu).ToList();
                if (pedidosNaoImpressos.Count > 0)
                {
                    foreach (var pedido in pedidosNaoImpressos)
                    {
                        if (pedido.CriadoPor != "SOPHOS")
                        {
                            await ImprimirPedido(pedido, false);
                            await PedidosService.UpdatePedidoImpresso(pedido);

                            await VizualizaSeNaoExistePedidoNaTela(pedido);

                        } //Só os integrações
                        else
                        {
                            await PedidosService.UpdatePedidoImpresso(pedido);
                        }
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao verificar pedidos não impressos: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnInfoAdicionalPedidoMudou(ClsPedido Pedido)
    {
        await CarregarPedidos();

        Snackbar.Add($"Atenção ao pedido {Pedido.DisplayId} criado por {Pedido.CriadoPor}, Temos novas informações sobre ele!", Severity.Info);
        await JS.InvokeVoidAsync("playNotificationSoundPedidoIfoodstatusNovo");
        await InvokeAsync(StateHasChanged);
    }
    private async Task OnEtapaPedidoMudou(ClsPedido novoPedido)
    {
        await CarregarPedidos();
        await InvokeAsync(StateHasChanged);
    }
    private async Task OnPedidoRecebido(ClsPedido novoPedido)
    {
        ProcessandoNovoPedido = true;
        try
        {
            bool? IntegraIfood = await LocalStorage.GetItemAsync<bool?>("IntegraIfood");

            if (IntegraIfood is not null && IntegraIfood == true && novoPedido.CriadoPor != "SOPHOS")
            {
                if (_items.Any(x => x.Pedido.Id == novoPedido.Id))
                {
                    await JS.InvokeVoidAsync("playNotificationSoundPedidoIntegracao");
                    Snackbar.Add("Você tem um pedido aguardando aceite!", Severity.Warning);
                    return;
                }

                await JS.InvokeVoidAsync("playNotificationSoundPedidoIntegracao");
                Snackbar.Add($"Novo Pedido {novoPedido.CriadoPor}", Severity.Info);
                await VizualizaSeNaoExistePedidoNaTela(novoPedido);

                if (novoPedido.CriadoPor == "SOPHOS CARDAPIO")
                   await EnviaMensagemNoWhatsAppDeUpdateDoPedido(novoPedido, EtapasPedido.PREPARANDO);

                if (AppState.MerchantLogado is not null && AppState.MerchantLogado.AceitaPedidoAutDeIntegracoes && (!novoPedido.PedidoAgendado && !(novoPedido.StatusPedido == "ABERTO")))
                    await ImprimirPedido(novoPedido, false);

                if (!novoPedido.PedidoAgendado)
                    await PedidosService.UpdatePedidoImpresso(novoPedido);

                await InvokeAsync(StateHasChanged);
                return;
            }

            if (novoPedido.EtapaPedido == "PREPARANDO")
                await EnviaMensagemNoWhatsAppDeUpdateDoPedido(novoPedido, EtapasPedido.PREPARANDO);


            await JS.InvokeVoidAsync("playNotificationSound");
            await VizualizaSeNaoExistePedidoNaTela(novoPedido);
            Snackbar.Add("Novo pedido recebido!", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao Obter pedido automaticamente, por favor atualize a página {ex.Message}", Severity.Error);
        }
        finally
        {
            ProcessandoNovoPedido = false;
        }

    }

    private async Task VizualizaSeNaoExistePedidoNaTela(ClsPedido pedido)
    {
        if (!_items.Any(x => x.Pedido.Id == pedido.Id))
        {
            _items.Insert(0, new ClsDeSuporteParaMostrarPedidos
            {
                Pedido = pedido,
                Selector = pedido.EtapaPedido
            });

            await InvokeAsync(StateHasChanged);
        }
    }
