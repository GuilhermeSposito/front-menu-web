    public async Task CarregarPedidos()
    {
        try
        {
            var result = await PedidosService.GetPedidosPorPaginaAsync(new QuerysDePedidos() { PageSize = PedidosPorVez, Pesquisa = pesquisaTexto, TipoPedido = FiltroPorTipoDePedido });


            if (result?.Data?.Any() == true)
            {
                foreach (var pedido in result.Data)
                {

                    foreach (var item in pedido.Itens)
                    {
                        if (item.Complementos?.Count > 1)
                            item.Complementos = item.Complementos.OrderBy(x => x.Id).ToList();
                    }
                }

                _items = result.Data.Select(p => new ClsDeSuporteParaMostrarPedidos
                {
                    Pedido = p,
                    Selector = p.EtapaPedido
                }).ToList();
            }
            else
            {
                Snackbar.Add("Nenhum pedido encontrado.", Severity.Warning);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Nenhum pedido encontrado.", Severity.Warning);
        }
        finally
        {
            CarregandoParteFiscal = false;
            ProgressoFiscal = 100;
            Carregando = false;
            await InvokeAsync(StateHasChanged);
        }
    }

