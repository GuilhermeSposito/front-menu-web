    private async Task EditarPedido(ClsPedido pedido)
    {
        ClsPedido? Pedido = await PedidosService.GetPedidoById(pedido.Id);
        if (Pedido is null)
        {
            Snackbar.Add("Erro ao obter detalhes do pedido, por favor tente novamente.", Severity.Error);
            return;
        }

        var parameters = new DialogParameters
        {
           { "NovoPedido", Pedido},
           { "Editando", true}
        };


        if (Pedido.TipoDePedido == "DELIVERY")
        {
            parameters["TiposDePedido"] = TiposDePedido.DELIVERY;
        }
        else if (Pedido.TipoDePedido == "BALCÂO")
        {
            parameters["TiposDePedido"] = TiposDePedido.BALCÃO;
        }
        else if (Pedido.TipoDePedido == "MESA")
        {
            parameters["TiposDePedido"] = TiposDePedido.MESA;
        }


        var options = new DialogOptions { MaxWidth = MaxWidth.False, FullWidth = false, FullScreen = false, CloseOnEscapeKey = false, BackdropClick = false };

        var dialog = await DialogService.ShowAsync<ModalDeCriarPedido>("Editar Pedido", parameters, options);
        var result = await dialog.Result;
        if (!result!.Canceled && result.Data is bool sucesso && sucesso)
        {
            await CarregarPedidos();
        }

    }
