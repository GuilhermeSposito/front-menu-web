@rendermode RenderMode.InteractiveWebAssembly
@attribute [Authorize]
@page "/nfs-estatisticas"
@inject IJSRuntime JS
@using FrontMenuWeb.Components.Modais.ModaisDeCadastros.Funcionarios
@using FrontMenuWeb.Components.Modais.ModaisDePessoas
@using FrontMenuWeb.Components.Uteis
@using FrontMenuWeb.DTOS
@using FrontMenuWeb.Models.Fiscal
@using FrontMenuWeb.Models.Merchant
@using FrontMenuWeb.Models.Pessoas
@using FrontMenuWeb.Services
@using FrontMenuWeb.Services.Fiscal
@using Microsoft.AspNetCore.Components
@using System.Globalization;
@using System.IO.Compression
@using MudBlazor.Extensions
@using MudBlazor.Services
@using MudBlazor.Extensions.Components
@using MudBlazor.Extensions.Services
@inject NfService NfService
@inject PedidosService PedidosService
@inject MerchantServices MerchantServices

<MudPaper Square="false" Elevation="0" class="@((Carregando ? "wait-cursor gestao-pedido-page" : ""))" Style="background-color: var(--mud-palette-background); min-height: 100vh; margin-top:10px">
    <MudLayout>
        <MudStack Row=true Wrap="Wrap.Wrap" Justify="Justify.SpaceBetween" Class="w-100 p-2 rounded-3" Style="background-color: var(--mud-palette-surface);">
            <MudStack Class="p-2">
                <MudText Typo="Typo.h4">NF-e NFC-e</MudText>
                <MudText Class="mb-3" Typo="Typo.body1">NF-e NFC-e Emitidas (Posição Físcal)</MudText>
            </MudStack>
            <MudStack Class="p-2" AlignItems="AlignItems.Center" Justify="Justify.Center" Row=true Wrap="Wrap.Wrap" Spacing="2">
               @* <MudFileUpload T="IBrowserFile" FilesChanged="UploadArquivo">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.CloudUpload">
                            Enviar Arquivos por Email Para Contabilidade
                        </MudButton>
                    </ActivatorContent>
                </MudFileUpload>*@
                <MudButton Variant="Variant.Filled"
                           Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.FolderZip"
                           Disabled="CarregandoEnvioDeEMail"
                           OnClick="EnviarXMLsValidosPorEmail">
                    Enviar XMLs Válidos do Período
                </MudButton>
            </MudStack>
        </MudStack>


        @if (CarregandoEnvioDeEMail)
        {
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.subtitle1">Enviando Email...</MudText>
                <MudProgressLinear Value="ProgressoFiscal" Color="Color.Primary" />
                <MudText Typo="Typo.caption">@ProgressoFiscal%</MudText>
            </MudPaper>
        }

        <FiltroPeriodoRapido Class="mt-2"
                             @bind-DataInicio="FiltroDateTimeInicial"
                             @bind-DataFim="FiltroDateTimeFinal"
                             OnFiltroAplicado="AplicarFiltros" />

        <MudDataGrid T="NFEmitidasDto"
                     @ref="dataGridRef"
                     EditTrigger="DataGridEditTrigger.Manual"
                     Class="rounded-3 custom-striped mt-2"
                     Loading="Carregando"
                     Hover
                     HorizontalScrollbar="false"
                     ServerData="LoadServerData"
                     MultiSelection=@MultiSelecao
                     SelectOnRowClick=@MultiSelecao
                     SelectedItems="NfsSelecionados"
                     SelectedItemsChanged="SelectedItemsChanged">
            <NoRecordsContent>
                <AvisoDeDadosVazios ReferenciaDados="NF-e NFC-e" />
            </NoRecordsContent>
            <ToolBarContent>
                <MudStack Row=true Class="w-100" Justify="Justify.Center" AlignItems="AlignItems.Center">
                    @if (MultiSelecao)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="() => { MultiSelecao = false; SelectedItemsChanged(new HashSet<NFEmitidasDto> { }); }">Cancelar Seleção</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="() => InutilizarNFsSelecionadas()">Inutilizar NFs Selecionadas</MudButton>
                    }
                </MudStack>
            </ToolBarContent>
            <Columns>
                @if (MultiSelecao)
                {
                    <SelectColumn T="NFEmitidasDto" />
                }
                <PropertyColumn Property="x => x.Id" Title="Id"></PropertyColumn>
                <TemplateColumn T="NFEmitidasDto" Title="Tipo">
                    <CellTemplate Context="context">
                        <MudText Style="font-weight:600" Color=@(context.Item.NfTipo == 55 ? Color.Success : Color.Error)>@(context.Item.NfTipo == 55 ? "NF-e" : "NFC-e")</MudText>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.NmrNf" Title="Nmr da NF"></PropertyColumn>
                <TemplateColumn T="NFEmitidasDto" Title="Nmr do Protocolo">
                    <CellTemplate Context="context">
                        @if (context.Item.NmrProtocolo is null)
                        {
                            <MudText Style="font-weight:600" Color=Color.Error>Protocolo Não Gerado</MudText>
                        }
                        else
                        {
                            <MudText Style="font-weight:600">@context.Item.NmrProtocolo</MudText>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.ChaveNf" Title="Chave"></PropertyColumn>
                <PropertyColumn Property="x => x.XMotivo" Title="Status"></PropertyColumn>
                <TemplateColumn T="NFEmitidasDto" Title="Status">
                    <CellTemplate Context="context">
                        <MudText Style="font-weight:600" Color=@(context.Item.CStat == 100 ? Color.Success : Color.Error)>@context.Item.CStat - @context.Item.XMotivo</MudText>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.CriadoEm" Title="Emissão" Format="dd/MM/yyyy"></PropertyColumn>

                <PropertyColumn Property="x => x.ValorTotalDaNf" Title="Valor da NF" Format="C"></PropertyColumn>

                <TemplateColumn T="NFEmitidasDto" Title="Ações">
                    <CellTemplate Context="context">
                        <MudTooltip Text="Clique para mais" Color="Color.Primary">
                            <MudMenu Icon="@Icons.Material.Filled.MoreVert">
                                <MudMenuItem OnClick=@(async () => { await ReimprimirNF(context.Item); }) Icon="@Icons.Material.Filled.Print" Label="Imprimir" />

                                <MudMenuItem OnClick=@(async () => { await DeletaRegistro(context.Item); }) Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error" Label="Cancelar" />

                                <MudMenuItem OnClick=@(async () => { MultiSelecao = !MultiSelecao; SelectedItemsChanged(new HashSet<NFEmitidasDto> { context.Item }); }) Icon="@Icons.Material.Filled.Close" IconColor="Color.Error" Label="Inultilizar" />
                            </MudMenu>
                        </MudTooltip>
                    </CellTemplate>
                </TemplateColumn>

            </Columns>
            <PagerContent>
                <MudDataGridPager T="NFEmitidasDto" RowsPerPageString="NF's por página" ShowPageNumber="false" PageSizeOptions=@(new int[] {20, 60, 70, 3000, 10000, 30000, 40000 }) />
            </PagerContent>
        </MudDataGrid>

        <MudGrid Class="w-100 mt-4" GutterSize="3">
            <!-- Total nfs válidas -->
            <MudItem xs="12" sm="6" md="4">
                <MudCard Class="rounded-2xl shadow-lg" Style="background: linear-gradient(135deg, #1B7FDB, #4AA8F0); color:white;">
                    <MudCardContent Class="flex flex-col items-center justify-center h-36">
                        <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="@Size.Medium" Class="mb-2 text-green-300" />
                        <MudText Typo="Typo.h6" Class="opacity-90">Total em NFs Válidas</MudText>
                        <MudText Typo="Typo.h4" Style="font-weight:600;">@TotalEmNFsValidas.ToString("C")</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Total das cendas -->
            <MudItem xs="12" sm="6" md="4">
                <MudCard Class="rounded-2xl shadow-lg" Style="background: linear-gradient(135deg, #409B44, #66BB6A); color:white;">
                    <MudCardContent Class="flex flex-col items-center justify-center h-36">
                        <MudIcon Icon="@Icons.Material.Filled.PendingActions" Size="@Size.Medium" Class="mb-2 text-red-300" />
                        <MudText Typo="Typo.h6" Class="opacity-90">Total das Vendas</MudText>
                        <MudText Typo="Typo.h4" Style="font-weight:600;">@TotalDasVendas.ToString("C")</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Total de pagamentos em cartões -->
            <MudItem xs="12" sm="12" md="4">
                <MudCard Class="rounded-2xl shadow-lg" Style="background: linear-gradient(135deg, #F88113, #FFB347); color:white;">
                    <MudStack Row=true>
                        <MudCardContent Class="flex flex-col items-center justify-center h-36">
                            <MudIcon Icon="@Icons.Material.Filled.Summarize" Size="@Size.Medium" Class="mb-2 text-yellow-200" />
                            <MudText Typo="Typo.h6" Class="opacity-90">Total de Pagamentos em Cartão</MudText>
                            <MudText Typo="Typo.h4" Style="font-weight:800;">@TotalDePagamentosEmCartoes.ToString("C")</MudText>
                        </MudCardContent>
                    </MudStack>
                </MudCard>
            </MudItem>

            <!-- Total de nfs canceladas -->
            <MudItem xs="12" sm="12" md="4">
                <MudCard Class="rounded-2xl shadow-lg" Style="background: linear-gradient(135deg, #F88113, #FFB347); color:white;">
                    <MudStack Row=true>
                        <MudCardContent Class="flex flex-col items-center justify-center h-36">
                            <MudIcon Icon="@Icons.Material.Filled.Summarize" Size="@Size.Medium" Class="mb-2 text-yellow-200" />
                            <MudText Typo="Typo.h6" Class="opacity-90">Canceladas</MudText>
                            <MudText Typo="Typo.h4" Style="font-weight:800;">@TotalDeNFsCanceladas.ToString("C")</MudText>
                        </MudCardContent>
                    </MudStack>
                </MudCard>
            </MudItem>

            <!-- Total de ICMS -->
            <MudItem xs="12" sm="12" md="4">
                <MudCard Class="rounded-2xl shadow-lg" Style="background: linear-gradient(135deg, #F88113, #FFB347); color:white;">
                    <MudStack Row=true>
                        <MudCardContent Class="flex flex-col items-center justify-center h-36">
                            <MudIcon Icon="@Icons.Material.Filled.Summarize" Size="@Size.Medium" Class="mb-2 text-yellow-200" />
                            <MudText Typo="Typo.h6" Class="opacity-90">Total do ICMS</MudText>
                            <MudText Typo="Typo.h4" Style="font-weight:800;">@TotalDeICMS.ToString("C")</MudText>
                        </MudCardContent>
                    </MudStack>
                </MudCard>
            </MudItem>

            <!-- Total de Tributos -->
            <MudItem xs="12" sm="12" md="4">
                <MudCard Class="rounded-2xl shadow-lg" Style="background: linear-gradient(135deg, #F88113, #FFB347); color:white;">
                    <MudStack Row=true>
                        <MudCardContent Class="flex flex-col items-center justify-center h-36">
                            <MudIcon Icon="@Icons.Material.Filled.Summarize" Size="@Size.Medium" Class="mb-2 text-yellow-200" />
                            <MudText Typo="Typo.h6" Class="opacity-90">Total dos Tributos</MudText>
                            <MudText Typo="Typo.h4" Style="font-weight:800;">@TotalDeTributos.ToString("C")</MudText>
                        </MudCardContent>
                    </MudStack>
                </MudCard>
            </MudItem>
        </MudGrid>

    </MudLayout>
</MudPaper>

@code {
    #region Props
    private MudDataGrid<NFEmitidasDto>? dataGridRef = new();

    private bool Carregando = true;

    //lógica do filtros
    private DateTime? FiltroDateTimeInicial = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime? FiltroDateTimeFinal = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(1).AddDays(-1);

    //Props dos totais
    private float TotalEmNFsValidas = 0;
    private float TotalDasVendas = 0;
    private float TotalDePagamentosEmCartoes = 0;
    private float TotalDeNFsCanceladas = 0;
    private float TotalDeICMS = 0;
    private float TotalDeTributos = 0;

    //Logica para escolher varias NFs
    private bool MultiSelecao = false;
    private HashSet<NFEmitidasDto> NfsSelecionados = new HashSet<NFEmitidasDto>();

    private bool CarregandoEnvioDeEMail = false;
    #endregion

    #region Função de load do Grid
    private async Task<GridData<NFEmitidasDto>> LoadServerData(GridState<NFEmitidasDto> itens)
    {
        try
        {
            Carregando = true;

            int page = itens.Page + 1;
            int pageSize = itens.PageSize;


            PaginatedResponse<NFEmitidasDto> result = await NfService.ConsultaNFeEmitidas(FiltroDateTimeInicial, FiltroDateTimeFinal, page, pageSize);
            TotalEmNFsValidas = result.ValorTotalDeNfsEmitidas;
            TotalDeNFsCanceladas = result.ValorTotalDasNfsCanceladas;


            StateHasChanged();

            return new GridData<NFEmitidasDto>
            {
                Items = result.Data,
                TotalItems = result.Total
            };

        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao carregar NFs: {ex.Message}", Severity.Error);
            return new GridData<NFEmitidasDto>
            {

            };

        }
        finally
        {
            Carregando = false;
            StateHasChanged();
        }
    }
    #endregion

    #region Funções de Ações da Página
    private async Task AplicarFiltros()
    {
        if (dataGridRef != null)
        {
            await dataGridRef.ReloadServerData();
        }
    }

    private async Task DeletaRegistro(NFEmitidasDto Registro)
    {
        if (!await AuthorizationService.ValidateAsync("AcessoEstatisticas")) return;
        try
        {
            var parameters = new DialogParameters<ModalDeExcluir>
            {
                    { x => x.ContentText, $"Você tem certeza que deseja excluir o Registtro da NF {Registro.NmrNf}? Atenção, essa ação não pode ser desfeita" },
                    { x => x.ButtonText, "Sim" },
                    { x => x.Color, Color.Error}
            };
            var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Large, CloseOnEscapeKey = true };
            var dialog = await DialogService.ShowAsync<ModalDeExcluir>("Confirmar Exclusão", parameters, options);
            var result = await dialog.Result;

            if (!result!.Canceled && result.Data is bool sucesso && sucesso)
            {
                var optionsInputText = new DialogOptions { CloseButton = true, FullScreen = true, FullWidth = true, MaxWidth = MaxWidth.ExtraExtraLarge, CloseOnEscapeKey = true };
                var dialogInputText = await DialogService.ShowAsync<Components.Modais.ModaisGenericos.InputText>("Motivo", parameters, options);
                var Motivo = await dialogInputText.Result;

                if (Motivo!.Canceled || string.IsNullOrWhiteSpace(Motivo.Data as string))
                {
                    Snackbar.Add("Motivo é obrigatório para exclusão da NF.", Severity.Error);
                    return;
                }

                var respostaApi = await NfService.CancelaNFe(Registro.ChaveNf!, Registro.NmrProtocolo!, Registro.NfTipo, Motivo: Motivo.Data.ToString());

                string MensagemDeRetorno = string.Join(", ", respostaApi.Status == "success" ? respostaApi.Data.Messages : respostaApi.Messages);
                Snackbar.Add(MensagemDeRetorno, respostaApi.Status == "success" ? Severity.Success : Severity.Error);


                if (respostaApi.Status == "success")
                    await dataGridRef!.ReloadServerData();
            }
        }
        catch (Exception ex) when (ex is NullReferenceException)
        {
            Snackbar.Add($"Erro ao excluir Registro: Campo nescessario não foi encontrado.", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao excluir Registro: {ex.Message}", Severity.Error);
            //ignorado
        }
    }

    private async Task ReimprimirNF(NFEmitidasDto registro)
    {
        if (!await AuthorizationService.ValidateAsync("AcessoEstatisticas")) return;
        await JS.InvokeVoidAsync("baixarXMLNF", registro.XmlDistribuicao, $"{registro.ChaveNf}-procnfe-copia.xml");
    }

    void SelectedItemsChanged(HashSet<NFEmitidasDto> items)
    {
        NfsSelecionados = items;
    }

    private async Task InutilizarNFsSelecionadas()
    {
        if (!await AuthorizationService.ValidateAsync("AcessoEstatisticas")) return;
        if (NfsSelecionados.Count == 0)
        {
            Snackbar.Add("Nenhuma NF selecionada para inutilização.", Severity.Warning);
            return;
        }
        // Lógica para inutilizar as NFs selecionadas
        // Exemplo: Chamar um serviço para processar a inutilização

        try
        {
            Carregando = true;

            //NFCE separado
            var NFCesSelecionadasOrganizadas = NfsSelecionados.Where(x => x.NfTipo == 65).OrderBy(x => x.NmrNf).ToList();
            NFEmitidasDto? PrimeiraNFCe = null;
            NFEmitidasDto? UltimaNFNfce = null;
            if (NFCesSelecionadasOrganizadas.Count > 0)
            {
                PrimeiraNFCe = NFCesSelecionadasOrganizadas.First();
                UltimaNFNfce = NFCesSelecionadasOrganizadas.Last();
            }

            //NFE separado
            var NFesSelecionadasOrganizadas = NfsSelecionados.Where(x => x.NfTipo == 55).OrderBy(x => x.NmrNf).ToList();
            NFEmitidasDto? PrimeiraNFe = null;
            NFEmitidasDto? UltimaNFNfe = null;
            if (NFesSelecionadasOrganizadas.Count > 0)
            {
                PrimeiraNFe = NFesSelecionadasOrganizadas.First();
                UltimaNFNfe = NFesSelecionadasOrganizadas.Last();
            }

            string MensagemDeConfirmacao = string.Empty;
            if (PrimeiraNFCe is not null)
                MensagemDeConfirmacao = $"Você tem certeza que deseja inutilizar Os Cupons Fiscais de número {PrimeiraNFCe.NmrNf} a {UltimaNFNfce.NmrNf}? Atenção, essa ação não pode ser desfeita";

            if (PrimeiraNFe is not null)
                MensagemDeConfirmacao += $"\n E Você tem certeza que deseja inutilizar As Notas Fiscais de número {PrimeiraNFe.NmrNf} a {UltimaNFNfe.NmrNf}? Atenção, essa ação não pode ser desfeita";

            var parameters = new DialogParameters<ModalDeExcluir>
            {
                    { x => x.ContentText, $"{MensagemDeConfirmacao}" },
                    { x => x.ButtonText, "Sim" },
                    { x => x.Color, Color.Error}
            };
            var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Large, CloseOnEscapeKey = true };
            var dialog = await DialogService.ShowAsync<ModalDeExcluir>("Confirmar Inutilização", parameters, options);
            var result = await dialog.Result;

            if (!result!.Canceled && result.Data is bool sucesso && sucesso)
            {
                //Primeiro montar o objeto de inutilização para nfce
                if (PrimeiraNFCe is not null && UltimaNFNfce is not null)
                {
                    InultilizacaoNFDto InuDto = new InultilizacaoNFDto
                    {
                        TipoNf = 65,
                        NumeroInicial = PrimeiraNFCe.NmrNf,
                        NumeroFinal = UltimaNFNfce.NmrNf,
                        Justificativa = "Inutilização em Lote pelo Sistema - Erro de Emissão"
                    };

                    ReturnApiRefatored<NFEmitidasDto> respostaApi = await NfService.InultilizaNFCe(InuDto);
                    MostraMensagemDeRetorno(respostaApi);
                }

                //Depois montar o objeto de inutilização para nf-e
                if (PrimeiraNFe is not null && UltimaNFNfe is not null)
                {
                    InultilizacaoNFDto InuDto = new InultilizacaoNFDto
                    {
                        TipoNf = 55,
                        NumeroInicial = PrimeiraNFe.NmrNf,
                        NumeroFinal = UltimaNFNfe.NmrNf,
                        Justificativa = "Inutilização em Lote pelo Sistema - Erro de Emissão"
                    };

                    ReturnApiRefatored<NFEmitidasDto> respostaApi = await NfService.InultilizaNFCe(InuDto);
                    MostraMensagemDeRetorno(respostaApi);
                }

                NfsSelecionados = new HashSet<NFEmitidasDto>();
                MultiSelecao = false;
                await dataGridRef?.ReloadServerData()!;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao inutilizar NFs: {ex.Message}", Severity.Error);
        }
        finally
        {
            Carregando = false;

        }
    }

    private void MostraMensagemDeRetorno<T>(ReturnApiRefatored<T> response)
    {
        var message = response.Status == "error"
            ? string.Join(", ", response.Messages)
            : string.Join(", ", response.Data?.Messages ?? new List<string>());

        var severity = response.Status == "error"
            ? Severity.Error
            : Severity.Success;

        Snackbar.Add(message, severity);
    }

    #endregion

    #region Função de envio de email para contabilidade

    private async Task EnviarXMLsValidosPorEmail()
    {
        if (!await AuthorizationService.ValidateAsync("AcessoEstatisticas")) return;
        try
        {
            string? EmailCadastrado = AppState.MerchantLogado?.EmailParaEnvioFiscais;

            if (string.IsNullOrEmpty(EmailCadastrado))
            {
                Snackbar.Add("Nenhum email cadastrado para envio. Por favor, informe um email.", Severity.Warning);

                var optionsInputText = new DialogOptions { CloseButton = true, FullScreen = false, FullWidth = false, MaxWidth = MaxWidth.ExtraLarge, CloseOnEscapeKey = true };
                var dialogInputText = await DialogService.ShowAsync<Components.Modais.ModaisGenericos.InputText>("Email para Envio", parameters: new DialogParameters<Components.Modais.ModaisGenericos.InputText>
                {
                    { x => x.ContentText, "Por favor, informe o email para envio dos arquivos de contabilidade." },
                    { x => x.ButtonText, "Salvar" },
                    { x => x.Color, Color.Primary },
                    { x => x.TamanhoMinimo, false }
                }, optionsInputText);
                var result = await dialogInputText.Result;

                if (result?.Data is string email && !string.IsNullOrEmpty(email))
                {
                    EmailCadastrado = email;

                    if (AppState.MerchantLogado is not null)
                    {
                        AppState.MerchantLogado.EmailParaEnvioFiscais = email;
                        var retorno = await MerchantServices.UpdateMerchantAsync(AppState.MerchantLogado);
                        if (retorno.Status == "success")
                        {
                            ClsMerchant merchant = await MerchantServices.GetMerchantAsync();
                            if (merchant is not null)
                                AppState.MerchantLogado = merchant;
                        }
                    }
                }
                else
                {
                    return;
                }
            }

            var resultado = await NfService.ConsultaNFeEmitidas(FiltroDateTimeInicial, FiltroDateTimeFinal, 1, 99999);

            var nfsComXml = resultado.Data
                .Where(x => (x.CStat == 100 || x.CStat == 110 || x.CStat == 150 || x.CStat == 250 || x.CStat == 301 || x.CStat == 302 || x.CStat == 303) && !string.IsNullOrEmpty(x.XmlDistribuicao))
                .ToList();

            if (nfsComXml.Count == 0)
            {
                Snackbar.Add("Nenhuma NF válida (CStat 100) com XML encontrada no período.", Severity.Warning);
                return;
            }

            ProgressoFiscal = 0;
            _progressCts = new CancellationTokenSource();
            CarregandoEnvioDeEMail = true;
            StateHasChanged();

            _ = SimulaProgressoAsync(_progressCts.Token);

            var zipStream = new MemoryStream();
            using (var archive = new ZipArchive(zipStream, ZipArchiveMode.Create, leaveOpen: true))
            {
                foreach (var nf in nfsComXml)
                {
                    var fileName = $"{nf.ChaveNf ?? nf.Id.ToString()}.xml";
                    var entry = archive.CreateEntry(fileName);
                    using var entryStream = entry.Open();
                    var xmlBytes = System.Text.Encoding.UTF8.GetBytes(nf.XmlDistribuicao!);
                    await entryStream.WriteAsync(xmlBytes);
                }
            }
            zipStream.Position = 0;

            var periodo = FiltroDateTimeInicial.HasValue
                ? FiltroDateTimeInicial.Value.ToString("MM-yyyy")
                : "todos";

            var zipName = $"XMLs-NFs-{periodo}.zip";
            var returno = await MerchantServices.EnviarArquicosParaContabilidadeEmail(zipStream, zipName, EmailCadastrado);
            MostraMensagemDeRetorno(returno);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao enviar XMLs: {ex.Message}", Severity.Error);
        }
        finally
        {
            CarregandoEnvioDeEMail = false;
            _progressCts?.Cancel();
            StateHasChanged();
        }
    }

    private async void UploadArquivo(IBrowserFile file)
    {
        if (!await AuthorizationService.ValidateAsync("AcessoEstatisticas")) return;
        try
        {
            string? EmailCadastrado = AppState.MerchantLogado?.EmailParaEnvioFiscais;

            ProgressoFiscal = 0;
            _progressCts = new CancellationTokenSource();

            const long maxFileSize = 20 * 1024 * 1024; // 20MB
            using var stream = file.OpenReadStream(maxFileSize);
            using var ms = new MemoryStream();

            if (string.IsNullOrEmpty(EmailCadastrado))
            {
                Snackbar.Add("Nenhum email cadastrado para envio. Por favor, informe um email.", Severity.Warning);

                var optionsInputText = new DialogOptions { CloseButton = true, FullScreen = false, FullWidth = false, MaxWidth = MaxWidth.ExtraLarge, CloseOnEscapeKey = true };
                var dialogInputText = await DialogService.ShowAsync<Components.Modais.ModaisGenericos.InputText>("Email para Envio", parameters: new DialogParameters<Components.Modais.ModaisGenericos.InputText>
                {
                    { x => x.ContentText, "Por favor, informe o email para envio dos arquivos de contabilidade." },
                    { x => x.ButtonText, "Salvar" },
                    { x => x.Color, Color.Primary },
                    { x => x.TamanhoMinimo, false }
                }, optionsInputText);
                var result = await dialogInputText.Result;

                if (result?.Data is string email && !string.IsNullOrEmpty(email))
                {
                    EmailCadastrado = email;

                    if (AppState.MerchantLogado is not null)
                    {
                        AppState.MerchantLogado.EmailParaEnvioFiscais = email;
                        var retorno = await MerchantServices.UpdateMerchantAsync(AppState.MerchantLogado);
                        if (retorno.Status == "success")
                        {
                            ClsMerchant merchant = await MerchantServices.GetMerchantAsync();
                            if (merchant is not null)
                                AppState.MerchantLogado = merchant;
                        }
                    }
                }

            }


            _ = SimulaProgressoAsync(_progressCts.Token);
            CarregandoEnvioDeEMail = true;

            await stream.CopyToAsync(ms);

            var returno = await MerchantServices.EnviarArquicosParaContabilidadeEmail(ms, file.Name, EmailCadastrado);
            MostraMensagemDeRetorno(returno);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao enviar email: {ex.Message}", Severity.Error);
        }
        finally
        {
            CarregandoEnvioDeEMail = false;
            _progressCts?.Cancel();
            StateHasChanged();
        }

    }

    int ProgressoFiscal = 0;
    CancellationTokenSource? _progressCts;
    private async Task SimulaProgressoAsync(CancellationToken token)
    {
        ProgressoFiscal = 0;

        while (ProgressoFiscal < 90 && !token.IsCancellationRequested)
        {
            await Task.Delay(30, token);
            ProgressoFiscal += Random.Shared.Next(2, 6);
            ProgressoFiscal = Math.Min(ProgressoFiscal, 98);
            await InvokeAsync(StateHasChanged);
        }
    }
    #endregion
}
