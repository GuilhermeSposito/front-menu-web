@rendermode RenderMode.InteractiveWebAssembly
@attribute [Authorize]
@page "/historico-suprimentos"
@using FrontMenuWeb.Models.Caixa
@using FrontMenuWeb.Services
@using FrontMenuWeb.Components.Uteis
@using System.Globalization

@inject SuprimentosService SuprimentosService
@inject IJSRuntime JS

<MudPaper Square="false" Elevation="0"
          Style="background-color: var(--mud-palette-background); min-height: 100vh; margin-top:10px">
    <MudLayout>

        @* Cabeçalho *@
        <MudStack Class="w-100 p-2 rounded-3" Style="background-color: var(--mud-palette-surface);">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="p-2"
                      Wrap="Wrap.Wrap">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.h4">Histórico de Suprimentos</MudText>
                    <MudText Class="mb-1" Typo="Typo.body1">Consulte o histórico completo de suprimentos de todos os
                        caixas</MudText>
                    </MudStack>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.PictureAsPdf" OnClick="GerarRelatorio"
                               Disabled="@(_gerandoRelatorio || _totais == null || _totais.Total == 0)">
                        @(_gerandoRelatorio ? "Gerando..." : "Gerar Relatório")
                    </MudButton>
                </MudStack>
            </MudStack>

            @* Filtros rápidos por período *@
            <FiltroPeriodoRapido Class="mt-2" @bind-DataInicio="_dataInicio" @bind-DataFim="_dataFim"
                                 OnFiltroAplicado="AplicarFiltros" Color="Color.Primary">
                <FiltroExtra>
                    <MudChipSet T="string" SelectedValue="_filtroStatus" SelectedValueChanged="OnStatusChanged"
                                SelectionMode="SelectionMode.SingleSelection">
                        <MudChip T="string" Value="@("")" Color="Color.Default" Variant="Variant.Outlined">Todos</MudChip>
                        <MudChip T="string" Value="@("Ativa")" Color="Color.Success" Variant="Variant.Outlined">Ativos
                        </MudChip>
                        <MudChip T="string" Value="@("Cancelada")" Color="Color.Error" Variant="Variant.Outlined">Cancelados
                        </MudChip>
                    </MudChipSet>
                </FiltroExtra>
            </FiltroPeriodoRapido>

            @* Cards de resumo *@
            @if (_totais is not null)
            {
                <MudGrid Spacing="2" Class="mt-2">
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Class="pa-3 rounded-3" Style="background-color: var(--mud-palette-surface);">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.caption">Total de Registros</MudText>
                                <MudText Typo="Typo.h5"><strong>@_totais.Total</strong></MudText>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Class="pa-3 rounded-3" Style="background-color: var(--mud-palette-surface);">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.caption">Total em Suprimentos Ativos</MudText>
                                <MudText Typo="Typo.h5" Color="Color.Success">
                                    <strong>@_totais.Data.Where(s => s.Status == "Ativa").Sum(s => s.Valor).ToString("C",
                                                                        CultureInfo.GetCultureInfo("pt-BR"))</strong>
                                    </MudText>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Class="pa-3 rounded-3" Style="background-color: var(--mud-palette-surface);">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.caption">Suprimentos Ativos</MudText>
                                    <MudText Typo="Typo.h5" Color="Color.Success">
                                        <strong>@_totais.Data.Count(s => s.Status == "Ativa")</strong>
                                    </MudText>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Class="pa-3 rounded-3" Style="background-color: var(--mud-palette-surface);">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.caption">Suprimentos Cancelados</MudText>
                                    <MudText Typo="Typo.h5" Color="Color.Error">
                                        <strong>@_totais.Data.Count(s => s.Status == "Cancelada")</strong>
                                    </MudText>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                }

                @* Tabela com paginação server-side *@
                <MudDataGrid T="ClsSuprimento" @ref="_dataGridRef" Class="rounded-3 mt-2" Loading="_carregando" Hover="true"
                             ServerData="CarregarDados">
                    <Columns>
                        <PropertyColumn Property="x => x.Id" Title="#" Sortable="false" />

                        <TemplateColumn Title="Data / Hora" Sortable="false">
                            <CellTemplate Context="context">
                                <MudText Typo="Typo.body2">
                                    @context.Item.CriadoEm.ToString("dd/MM/yyyy HH:mm", CultureInfo.GetCultureInfo("pt-BR"))
                                </MudText>
                            </CellTemplate>
                        </TemplateColumn>

                        <PropertyColumn Property="x => x.Descricao" Title="Descrição" Sortable="false" />

                        <TemplateColumn Title="Valor" Sortable="false">
                            <CellTemplate Context="context">
                                <MudText Typo="Typo.body2" Color="Color.Success">
                                    <strong>@context.Item.Valor.ToString("C", CultureInfo.GetCultureInfo("pt-BR"))</strong>
                                </MudText>
                            </CellTemplate>
                        </TemplateColumn>

                        <TemplateColumn Title="Status" Sortable="false">
                            <CellTemplate Context="context">
                                @if (context.Item.Status == "Ativa")
                                {
                                    <MudChip T="string" Color="Color.Success" Size="Size.Small"
                                             Icon="@Icons.Material.Filled.CheckCircle">
                                        Ativo
                                    </MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Color="Color.Error" Size="Size.Small" Icon="@Icons.Material.Filled.Cancel">
                                        Cancelado
                                    </MudChip>
                                }
                            </CellTemplate>
                        </TemplateColumn>

                        <TemplateColumn Title="Funcionário" Sortable="false">
                            <CellTemplate Context="context">
                                <MudText Typo="Typo.body2">@(context.Item.Funcionario?.Nome ?? "—")</MudText>
                            </CellTemplate>
                        </TemplateColumn>

                        <TemplateColumn Title="Cancelado Por" Sortable="false">
                            <CellTemplate Context="context">
                                <MudText Typo="Typo.body2">@(context.Item.CanceladoPorFuncionario?.Nome ?? "—")</MudText>
                            </CellTemplate>
                        </TemplateColumn>

                        <TemplateColumn Title="Cancelado Em" Sortable="false">
                            <CellTemplate Context="context">
                                <MudText Typo="Typo.body2">
                                    @(context.Item.CanceladoEm.HasValue
                                        ? context.Item.CanceladoEm.Value.ToString("dd/MM/yyyy HH:mm",
                                    CultureInfo.GetCultureInfo("pt-BR"))
                                        : "—")
                                </MudText>
                            </CellTemplate>
                        </TemplateColumn>

                        <TemplateColumn Title="Motivo Cancelamento" Sortable="false">
                            <CellTemplate Context="context">
                                <MudText Typo="Typo.body2">@(context.Item.MotivoCancelamento ?? "—")</MudText>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>

                    <NoRecordsContent>
                        <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="pa-6">
                            <MudIcon Icon="@Icons.Material.Filled.Savings" Size="Size.Large" Color="Color.Secondary" />
                            <MudText Typo="Typo.h6" Color="Color.Secondary">Nenhum suprimento encontrado</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Tente ajustar os filtros para encontrar
                                registros.</MudText>
                            </MudStack>
                        </NoRecordsContent>

                        <LoadingContent>
                            <MudStack AlignItems="AlignItems.Center" Class="pa-6">
                                <MudProgressCircular Indeterminate="true" Color="Color.Success" />
                                <MudText>Carregando histórico de suprimentos...</MudText>
                            </MudStack>
                        </LoadingContent>

                        <PagerContent>
                            <MudDataGridPager T="ClsSuprimento" RowsPerPageString="Registros por página" ShowPageNumber="false"
                                              PageSizeOptions="@(new int[] { 10, 20, 50, 100 })" />
                        </PagerContent>
                    </MudDataGrid>

                </MudLayout>
            </MudPaper>

@code {
    private MudDataGrid<ClsSuprimento>? _dataGridRef;
    private bool _carregando = false;
    private string _filtroStatus = string.Empty;
    private DateTime? _dataInicio = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime? _dataFim = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(1).AddDays(-1);
    private PaginatedResponse<ClsSuprimento>? _totais;

    private async Task<GridData<ClsSuprimento>> CarregarDados(GridState<ClsSuprimento> state)
    {
        try
        {
            _carregando = true;

            int page = state.Page + 1;
            int pageSize = state.PageSize;
            string? status = string.IsNullOrEmpty(_filtroStatus) ? null : _filtroStatus;

            var resultado = await SuprimentosService.GetAllSuprimentosPaginatedAsync(page, pageSize, status, _dataInicio, _dataFim);
            _totais = resultado;

            StateHasChanged();

            return new GridData<ClsSuprimento>
            {
                Items = resultado.Data,
                TotalItems = resultado.Total
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao carregar histórico de suprimentos: {ex.Message}", Severity.Error);
            return new GridData<ClsSuprimento>();
        }
        finally
        {
            _carregando = false;
        }
    }

    private async Task OnStatusChanged(string status)
    {
        _filtroStatus = status;
        await AplicarFiltros();
    }

    private async Task AplicarFiltros()
    {
        if (_dataGridRef is not null)
            await _dataGridRef.ReloadServerData();
    }

    private bool _gerandoRelatorio = false;
    private List<ClsSuprimento> _dadosRelatorio = new();

    private async Task GerarRelatorio()
    {
        try
        {
            _gerandoRelatorio = true;
            StateHasChanged();

            string? status = string.IsNullOrEmpty(_filtroStatus) ? null : _filtroStatus;
            var resultado = await SuprimentosService.GetAllSuprimentosPaginatedAsync(1, _totais?.Total ?? 10000, status,
_dataInicio, _dataFim);
            _dadosRelatorio = resultado.Data;

            if (_dadosRelatorio.Count == 0)
            {
                Snackbar.Add("Nenhum suprimento encontrado para gerar o relatório.", Severity.Warning);
                return;
            }

            StateHasChanged();
            await Task.Delay(50);

            await JS.InvokeVoidAsync("generatePdfFromHtml", "relatorio-suprimentos", "RelatorioSuprimentos.pdf");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao gerar relatório: {ex.Message}", Severity.Error);
        }
        finally
        {
            _gerandoRelatorio = false;
            StateHasChanged();
        }
    }

}

@* Relatório PDF *@
<div id="relatorio-suprimentos" style="font-family: Arial, sans-serif; font-size: 12px; color: #333; display:none">
    <div style="text-align:center; margin-bottom:20px;">
        <img src="/images/SOPHOS.png" alt="Logo" style="width:150px; display:block; margin: 0 auto 10px;" />
        <h2 style="color:#2c3e50; margin:0;">Relatório de Histórico de Suprimentos</h2>
        <p style="margin:4px 0;">@AppState.MerchantLogado.NomeFantasia</p>
        <p style="margin:4px 0;">Período: @(_dataInicio?.ToString("dd/MM/yyyy") ?? "Início") até
            @(_dataFim?.ToString("dd/MM/yyyy") ?? "Hoje")</p>
            @if (!string.IsNullOrEmpty(_filtroStatus))
            {
                <p style="margin:4px 0;">Filtro de status: @(_filtroStatus == "Ativa" ? "Ativos" : "Cancelados")</p>
            }
            <p style="margin:4px 0; font-size:10px; color:#777;">Emitido em: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
        </div>

        @{
            var relAtivos = _dadosRelatorio.Where(s => s.Status == "Ativa").ToList();
            var relCancelados = _dadosRelatorio.Where(s => s.Status == "Cancelada").ToList();
        }

        <div style="display:flex; gap:20px; margin-bottom:20px; background:#f8f9fa; padding:12px; border-radius:6px;">
            <div><strong>Total de Registros:</strong> @_dadosRelatorio.Count</div>
            <div><strong>Suprimentos Ativos:</strong> @relAtivos.Count</div>
            <div><strong>Suprimentos Cancelados:</strong> @relCancelados.Count</div>
            <div><strong>Total em Suprimentos Ativos:</strong> @relAtivos.Sum(s => s.Valor).ToString("C",
                            CultureInfo.GetCultureInfo("pt-BR"))</div>
            </div>

            <table border="0" cellspacing="0" cellpadding="6" style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="background-color:#34495e; color:white; text-align:center;">
                        <th>#</th>
                        <th>Data / Hora</th>
                        <th style="text-align:left;">Descrição</th>
                        <th>Valor</th>
                        <th>Status</th>
                        <th>Funcionário</th>
                        <th>Cancelado Por</th>
                        <th>Motivo Cancelamento</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var relatorioIndex = 0;
                    }
                    @foreach (var suprimento in _dadosRelatorio)
                    {
                        relatorioIndex++;
                        var bgColor = relatorioIndex % 2 == 0 ? "#f9f9f9" : "white";
                        <tr style="border-bottom:1px solid #ddd; text-align:center; background-color:@bgColor">
                            <td>@suprimento.Id</td>
                            <td>@suprimento.CriadoEm.ToString("dd/MM/yyyy HH:mm", CultureInfo.GetCultureInfo("pt-BR"))</td>
                            <td style="text-align:left;">@suprimento.Descricao</td>
                            <td style="text-align:right; color:#27ae60; font-weight:600;">@suprimento.Valor.ToString("C",
                                                    CultureInfo.GetCultureInfo("pt-BR"))</td>
                                <td style="color:@(suprimento.Status == "Ativa" ? "#27ae60" : "#c0392b"); font-weight:bold;">
                                    @(suprimento.Status == "Ativa" ? "Ativo" : "Cancelado")</td>
                                    <td>@(suprimento.Funcionario?.Nome ?? "—")</td>
                                    <td>@(suprimento.CanceladoPorFuncionario?.Nome ?? "—")</td>
                                    <td>@(suprimento.MotivoCancelamento ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr style="background-color:#2c3e50; color:white; font-weight:bold; text-align:center;">
                                <td colspan="3" style="text-align:right;">Total em Suprimentos Ativos:</td>
                                <td style="text-align:right;">@relAtivos.Sum(s => s.Valor).ToString("C",
                                                        CultureInfo.GetCultureInfo("pt-BR"))</td>
                                    <td colspan="4"></td>
                                </tr>
                                @if (relCancelados.Count > 0)
                                {
                                    <tr style="background-color:#ecf0f1; font-weight:bold; text-align:center;">
                                        <td colspan="3" style="text-align:right;">Total em Suprimentos Cancelados:</td>
                                        <td style="text-align:right; color:#c0392b;">@relCancelados.Sum(s => s.Valor).ToString("C",
                                                                CultureInfo.GetCultureInfo("pt-BR"))</td>
                                            <td colspan="4"></td>
                                        </tr>
                                    }
                                </tfoot>
                            </table>

                            <div style="margin-top:30px; text-align:center; font-size:10px; color:#777;">
                                <hr style="border:none; border-top:1px solid #ccc; margin:10px 0;">
                                <p>Relatório gerado automaticamente — SOPHOS Sistema de Gestão</p>
                            </div>
                        </div>
