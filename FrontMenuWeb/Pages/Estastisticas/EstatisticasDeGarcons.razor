@rendermode RenderMode.InteractiveWebAssembly
@attribute [Authorize]
@page "/vendas/estatisticas-de-garcons"
@using FrontMenuWeb.Components.Uteis
@using FrontMenuWeb.DTOS
@using FrontMenuWeb.Services
@using FrontMenuWeb.Models.Merchant
@using System.Globalization
@inject PedidosService PedidosService
@inject GarconService GarconService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<MudPaper Square="false" Elevation="0" Style="background-color: var(--mud-palette-background); min-height: 100vh">
    <MudLayout>

        <MudStack Class="w-100 p-3 rounded-2" Style="background-color: var(--mud-palette-surface)">
            <MudText Typo="Typo.h5">Estatísticas de Garçons</MudText>
        </MudStack>

        <FiltroPeriodoRapido Class="mt-2"
                             @bind-DataInicio="FiltroInicio"
                             @bind-DataFim="FiltroFinal"
                             OnFiltroAplicado="Carregar" />

        <MudStack Class="w-100 p-3 rounded-2 mt-2" Style="background-color: var(--mud-palette-surface)">
            <MudSelect T="ClsGarcon"
                       MultiSelection="true"
                       @bind-SelectedValues="GarconsSelecionados"
                       @bind-SelectedValues:after="Carregar"
                       Label="Filtrar por garçons (deixe vazio para todos)"
                       Placeholder="Selecione um ou mais garçons..."
                       Clearable="true"
                       ToStringFunc="@(g => g?.Nome ?? string.Empty)"
                       Variant="Variant.Filled"
                       AnchorOrigin="Origin.BottomCenter">
                @foreach (var garcon in TodosGarcons)
                {
                    <MudSelectItem T="ClsGarcon" Value="@garcon">@garcon.Nome</MudSelectItem>
                }
            </MudSelect>
        </MudStack>

        <MudGrid Class="mt-2 px-2">
            <MudItem xs="12" sm="4">
                <MudPaper Class="pa-4 rounded-3" Style="background-color: var(--mud-palette-surface)">
                    <MudStack AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Color="Color.Success" Size="Size.Large" />
                        <MudText Typo="Typo.subtitle1">Total de Vendas</MudText>
                        <MudText Typo="Typo.h4" Color="Color.Success">@((Dados?.TotalDeVendas ?? 0).ToString("C", CultureInfo.GetCultureInfo("pt-BR")))</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Class="pa-4 rounded-3" Style="background-color: var(--mud-palette-surface)">
                    <MudStack AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.Inventory2" Color="Color.Primary" Size="Size.Large" />
                        <MudText Typo="Typo.subtitle1">Total de Itens Vendidos</MudText>
                        <MudText Typo="Typo.h4" Color="Color.Primary">@((Dados?.TotalItensVendidos ?? 0).ToString("N0"))</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Class="pa-4 rounded-3" Style="background-color: var(--mud-palette-surface)">
                    <MudStack AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.Percent" Color="Color.Warning" Size="Size.Large" />
                        <MudText Typo="Typo.subtitle1">Taxa de Serviço</MudText>
                        <MudText Typo="Typo.h4" Color="Color.Warning">@((Dados?.TaxaDeServicoPorcentagem ?? 0).ToString("N2"))%</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Class="pa-3 rounded-3 mt-2" Style="background-color: var(--mud-palette-surface)">
            <MudText Typo="Typo.subtitle1" Class="mb-2">Ranking de Vendas por Garçom (R$)</MudText>
            @if (Carregando)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
            <div style="height:300px; position:relative;">
                <canvas id="chart-garcons-valor"></canvas>
            </div>
        </MudPaper>

        <MudPaper Class="pa-3 rounded-3 mt-2" Style="background-color: var(--mud-palette-surface)">
            <MudText Typo="Typo.subtitle1" Class="mb-2">Participação nas Vendas (%)</MudText>
            @if (Carregando)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
            <div style="height:300px; position:relative;">
                <canvas id="chart-garcons-pct"></canvas>
            </div>
        </MudPaper>

        <MudStack Class="w-100 p-3 rounded-2 mt-2" Style="background-color: var(--mud-palette-surface)">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.subtitle1">Detalhamento por Garçom</MudText>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.PictureAsPdf"
                           OnClick="GerarRelatorio"
                           Disabled="@(Dados == null || !Dados.Garcons.Any())">
                    Gerar Relatório
                </MudButton>
            </MudStack>

            <MudDataGrid T="DtoGarconEstatistica"
                         Items="@(Dados?.Garcons ?? new())"
                         Loading="Carregando"
                         Class="rounded-3 custom-striped"
                         Hover Dense>
                <NoRecordsContent>
                    <AvisoDeDadosVazios ReferenciaDados="Garçons" />
                </NoRecordsContent>
                <Columns>
                    <TemplateColumn Title="Posição">
                        <CellTemplate>
                            @{
                                var pos = (Dados?.Garcons?.IndexOf(context.Item) ?? -1) + 1;
                            }
                            <MudText Style="font-weight:600" Color="@(pos == 1 ? Color.Warning : pos == 2 ? Color.Default : pos == 3 ? Color.Tertiary : Color.Default)">
                                @(pos == 1 ? "🥇" : pos == 2 ? "🥈" : pos == 3 ? "🥉" : $"#{pos}")
                            </MudText>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Garçom">
                        <CellTemplate>
                            <MudStack Spacing="0">
                                <MudText Style="font-weight:500">@context.Item.Garcon.Nome</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Item.Garcon.NomeUsuario</MudText>
                            </MudStack>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Valor de Vendas">
                        <CellTemplate>
                            <MudText Color="Color.Success" Style="font-weight:600">@context.Item.ValorDeVendas.ToString("C", CultureInfo.GetCultureInfo("pt-BR"))</MudText>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Taxa de Serviço">
                        <CellTemplate>
                            <MudText Color="Color.Warning">@context.Item.ValorTaxaDeServico.ToString("C", CultureInfo.GetCultureInfo("pt-BR"))</MudText>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="% das Vendas">
                        <CellTemplate>
                            <MudStack Spacing="1">
                                <MudText>@context.Item.ValorEmPorcentagem.ToString("N2")%</MudText>
                                <MudProgressLinear Value="@context.Item.ValorEmPorcentagem" Max="100" Color="Color.Primary" Size="Size.Small" Rounded="true" />
                            </MudStack>
                        </CellTemplate>
                    </TemplateColumn>
                    <PropertyColumn Property="x => x.QtdItensVendidos" Title="Qtd. Itens" Format="N0" />
                    <PropertyColumn Property="x => x.QtdLinhasDePedido" Title="Linhas de Pedido" Format="N0" />
                </Columns>
            </MudDataGrid>
        </MudStack>

    </MudLayout>
</MudPaper>

@code {
    private DateTime? FiltroInicio { get; set; }
    private DateTime? FiltroFinal { get; set; }
    private bool Carregando = true;

    private List<ClsGarcon> TodosGarcons = new();
    private IEnumerable<ClsGarcon> GarconsSelecionados { get; set; } = Enumerable.Empty<ClsGarcon>();

    private DtoEstatisticaGarcons? Dados;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var retGarcons = await GarconService.GetGarconsAsync();
            TodosGarcons = retGarcons.Data?.Lista ?? new();
            await Carregar();
        }
    }

    private async Task Carregar()
    {
        try
        {
            Carregando = true;
            StateHasChanged();

            var ids = GarconsSelecionados.Any() ? GarconsSelecionados.Select(g => g.Id).ToList() : null;
            Dados = await PedidosService.EstastisticaDeGarcons(FiltroInicio, FiltroFinal, ids);

            if (Dados == null)
                Snackbar.Add("Erro ao carregar dados dos garçons.", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Erro: " + ex.Message, Severity.Error);
            Dados = null;
        }
        finally
        {
            Carregando = false;
            StateHasChanged();
            await RenderizarGraficos();
        }
    }

    private async Task RenderizarGraficos()
    {
        await Task.Delay(50);
        try
        {
            var garcons = Dados?.Garcons ?? new();
            var labels = garcons.Select(g => g.Garcon.Nome).ToArray();
            var valores = garcons.Select(g => g.ValorDeVendas).ToArray();
            var porcentagens = garcons.Select(g => g.ValorEmPorcentagem).ToArray();

            await JS.InvokeVoidAsync("SophosCharts.renderBar", "chart-garcons-valor", labels, valores, "Vendas (R$)", "#3dcb6c");
            await JS.InvokeVoidAsync("SophosCharts.renderBar", "chart-garcons-pct", labels, porcentagens, "Participação (%)", "#4a86ff");
        }
        catch { }
    }

    private async Task GerarRelatorio()
    {
        await JS.InvokeVoidAsync("generatePdfFromHtml", "relatorio-garcons", "RelatorioGarcons.pdf");
    }
}

@* Relatório PDF *@
<div id="relatorio-garcons" style="font-family: Arial, sans-serif; font-size: 12px; color: #333; display:none">
    <div style="text-align:center; margin-bottom:20px;">
        <img src="/images/SOPHOS.png" alt="Logo" style="width:150px; display:block; margin: 0 auto 10px;" />
        <h2 style="color:#2c3e50; margin:0;">Relatório de Estatísticas de Garçons</h2>
        <p style="margin:4px 0;">Período: @(FiltroInicio?.ToString("dd/MM/yyyy") ?? "Início") até @(FiltroFinal?.ToString("dd/MM/yyyy") ?? "Hoje")</p>
        <p style="margin:4px 0; font-size:10px; color:#777;">Emitido em: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
    </div>

    <div style="display:flex; gap:20px; margin-bottom:20px; background:#f8f9fa; padding:12px; border-radius:6px;">
        <div><strong>Total de Vendas:</strong> @((Dados?.TotalDeVendas ?? 0).ToString("C", CultureInfo.GetCultureInfo("pt-BR")))</div>
        <div><strong>Total de Itens:</strong> @((Dados?.TotalItensVendidos ?? 0).ToString("N0"))</div>
        <div><strong>Taxa de Serviço:</strong> @((Dados?.TaxaDeServicoPorcentagem ?? 0).ToString("N2"))%</div>
    </div>

    <table border="0" cellspacing="0" cellpadding="6" style="width:100%; border-collapse:collapse;">
        <thead>
            <tr style="background-color:#34495e; color:white; text-align:center;">
                <th>#</th>
                <th style="text-align:left;">Garçom</th>
                <th>Valor de Vendas</th>
                <th>Taxa de Serviço</th>
                <th>% das Vendas</th>
                <th>Qtd. Itens</th>
                <th>Linhas Pedido</th>
            </tr>
        </thead>
        <tbody>
            @if (Dados != null)
            {
                var totalTaxa = Dados.Garcons.Sum(g => g.ValorTaxaDeServico);
                var relatorioIndex = 0;
                foreach (var item in Dados.Garcons)
                {
                    relatorioIndex++;
                    var bgColor = relatorioIndex % 2 == 0 ? "#f9f9f9" : "white";
                    <tr style="border-bottom:1px solid #ddd; text-align:center; background-color:@bgColor">
                        <td style="font-weight:600;">@relatorioIndex</td>
                        <td style="text-align:left;">
                            <strong>@item.Garcon.Nome</strong><br />
                            <span style="font-size:10px; color:#777;">@item.Garcon.NomeUsuario</span>
                        </td>
                        <td style="color:#27ae60; font-weight:600;">@item.ValorDeVendas.ToString("C", CultureInfo.GetCultureInfo("pt-BR"))</td>
                        <td style="color:#e67e22;">@item.ValorTaxaDeServico.ToString("C", CultureInfo.GetCultureInfo("pt-BR"))</td>
                        <td>@item.ValorEmPorcentagem.ToString("N2")%</td>
                        <td>@item.QtdItensVendidos.ToString("N0")</td>
                        <td>@item.QtdLinhasDePedido.ToString("N0")</td>
                    </tr>
                }
                <tr style="background-color:#2c3e50; color:white; font-weight:bold; text-align:center;">
                    <td colspan="2" style="text-align:right;">Totais:</td>
                    <td>@Dados.TotalDeVendas.ToString("C", CultureInfo.GetCultureInfo("pt-BR"))</td>
                    <td>@totalTaxa.ToString("C", CultureInfo.GetCultureInfo("pt-BR"))</td>
                    <td>100%</td>
                    <td>@Dados.TotalItensVendidos.ToString("N0")</td>
                    <td>—</td>
                </tr>
            }
        </tbody>
    </table>

    <div style="margin-top:30px; text-align:center; font-size:10px; color:#777;">
        <hr style="border:none; border-top:1px solid #ccc; margin:10px 0;">
        <p>Relatório gerado automaticamente — SOPHOS Sistema de Gestão</p>
    </div>

    <div style="page-break-after:always;"></div>
</div>
