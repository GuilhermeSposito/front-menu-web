@rendermode RenderMode.InteractiveWebAssembly
@using FrontMenuWeb.DTOS
@using FrontMenuWeb.Models.Caixa
@using FrontMenuWeb.Services
@using System.Globalization

@inject SuprimentosService SuprimentosService
@inject IJSRuntime JS

<MudDialog>
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Savings" Color="Color.Success" />
            <MudText Typo="Typo.h6">Novo Suprimento de Caixa</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudStack Spacing="3">
                <MudAlert Severity="Severity.Info" Dense="true">
                    Caixa <strong>#@CaixaId</strong> está aberto. Informe o valor e a descrição do suprimento.
                </MudAlert>

                <MudNumericField T="decimal"
                                 @bind-Value="_valor"
                                 id="valor-suprimento"
                                 @onfocus="@(async e => await JS.InvokeVoidAsync("selectAllInput", "valor-suprimento"))"
                                 Label="Valor do Suprimento (R$)"
                                 Adornment="Adornment.Start"
                                 AdornmentText="R$"
                                 Min="0.01m"
                                 Format="N2"
                                 Culture="@CultureInfo.GetCultureInfo("pt-BR")"
                                 Required="true"
                                 RequiredError="O valor é obrigatório e deve ser maior que zero."
                                 Variant="Variant.Outlined" />

                <MudTextField @bind-Value="_descricao"
                              Label="Descrição"
                              Required="true"
                              RequiredError="A descrição é obrigatória."
                              MaxLength="500"
                              Lines="3"
                              Variant="Variant.Outlined"
                              Placeholder="Ex: Troco para abertura do caixa..." />
            </MudStack>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancelar" Disabled="_salvando">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Success"
                   OnClick="Confirmar"
                   Disabled="_salvando || !_formValido"
                   StartIcon="@Icons.Material.Filled.Savings">
            @if (_salvando)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Registrando...</span>
            }
            else
            {
                <span>Registrar Suprimento</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public int CaixaId { get; set; }

    private MudForm _form = default!;
    private bool _formValido = false;
    private bool _salvando = false;
    private decimal _valor = 0m;
    private string _descricao = string.Empty;

    private void Cancelar() => MudDialog.Cancel();

    private async Task Confirmar()
    {
        await _form.Validate();
        if (!_formValido) return;

        if (_valor <= 0)
        {
            Snackbar.Add("O valor do suprimento deve ser maior que zero.", Severity.Warning);
            return;
        }

        _salvando = true;
        try
        {
            var dto = new CreateSuprimentoDto
            {
                CaixaId = CaixaId,
                Descricao = _descricao,
                Valor = _valor
            };

            var resultado = await SuprimentosService.CreateSuprimentoAsync(dto);

            if (resultado.Status == "success")
            {
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                string mensagem = string.Join(", ", resultado.Messages);
                Snackbar.Add(mensagem, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao registrar suprimento: {ex.Message}", Severity.Error);
        }
        finally
        {
            _salvando = false;
        }
    }
}
