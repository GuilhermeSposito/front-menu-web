@rendermode RenderMode.InteractiveWebAssembly
@using FrontMenuWeb.Services
@inject SangriasService SangriasService

<MudDialog>
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Security" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Autorização Necessária</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudFocusTrap DefaultFocus="_defaultFocus">
            <MudText Typo="Typo.body2" Class="mb-4">
                Você não tem permissão para esta ação. Solicite que um supervisor ou administrador autorize informando as credenciais abaixo:
            </MudText>

            <MudTextField T="string" 
                          Label="E-mail" 
                          @bind-Value="_email" 
                          Variant="Variant.Outlined" 
                          Immediate="true"
                          OnKeyDown="@HandleKeyDown"
                          Class="mb-3" />

            <MudTextField T="string" 
                          Label="Senha" 
                          @bind-Value="_senha" 
                          @ref="_passwordField"
                          Variant="Variant.Outlined" 
                          InputType="InputType.Password" 
                          Immediate="true"
                          OnKeyDown="@HandleKeyDown" />
        </MudFocusTrap>

        @if (!string.IsNullOrEmpty(_mensagemErro))
        {
            <MudText Color="Color.Error" Typo="Typo.caption" Class="mt-2">@_mensagemErro</MudText>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Variant="Variant.Text">Cancelar</MudButton>
        <MudButton Color="Color.Primary" 
                   Variant="Variant.Filled" 
                   OnClick="Submit" 
                   Disabled="_carregando">
            @if (_carregando)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">Validando...</MudText>
            }
            else
            {
                <MudText>Autorizar</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public string PermissionName { get; set; } = "";

    private MudTextField<string> _passwordField;
    private DefaultFocus _defaultFocus = DefaultFocus.FirstChild;

    private string _email = "";
    private string _senha = "";
    private string _mensagemErro = "";
    private bool _carregando = false;
    private bool _focusSet = false;

    protected override async Task OnInitializedAsync()
    {
        var savedEmail = await LocalStorage.GetItemAsync<string>("last_supervisor_email");
        if (!string.IsNullOrWhiteSpace(savedEmail))
        {
            _email = savedEmail;
            _defaultFocus = DefaultFocus.LastChild;
        }
    }

    private void Cancelar() => MudDialog.Cancel();

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_senha))
        {
            _mensagemErro = "Preencha todos os campos.";
            return;
        }

        _carregando = true;
        _mensagemErro = "";
        try
        {
            var result = await SangriasService.ValidateAuthorizeAsync(_email, _senha, PermissionName);
            if (result.Allowed)
            {
                await LocalStorage.SetItemAsync("last_supervisor_email", _email);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                _mensagemErro = result.Message.FirstOrDefault() ?? "Autorização negada.";
            }
        }
        catch (Exception ex)
        {
            _mensagemErro = $"Erro na comunicação: {ex.Message}";
        }
        finally
        {
            _carregando = false;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Submit();
        }
    }
}
