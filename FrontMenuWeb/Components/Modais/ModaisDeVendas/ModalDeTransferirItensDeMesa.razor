@rendermode RenderMode.InteractiveWebAssembly
@using FrontMenuWeb.Models.Merchant
@using FrontMenuWeb.Services
@inject MesasServices MesasServices
@inject PedidosService PedidosService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Transferir Itens</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.body2">
                Transferindo <strong>@ItemIds.Count</strong> item(ns) da @(AppState.MerchantLogado?.LegendaNomeUltilizadoParaPlaced ?? "Mesa") <strong>@CodigoExternoOrigem</strong>.
            </MudText>
            <MudNumericField @bind-Value="_codigoDestinoDigitado"
                             Label="@($"Número da {AppState.MerchantLogado?.LegendaNomeUltilizadoParaPlaced ?? "Mesa"} de destino")"
                             Variant="Variant.Outlined"
                             Min="1"
                             HideSpinButtons="true"
                             Immediate="true"
                             Error="@(_erroMesa is not null)"
                             ErrorText="@_erroMesa" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Variant="Variant.Text">Cancelar</MudButton>
        <MudButton OnClick="Confirmar"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@(_processando || _codigoDestinoDigitado <= 0)">
            @if (_processando)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
            }
            Transferir
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public int MesaOrigemId { get; set; }
    [Parameter] public int CodigoExternoOrigem { get; set; }
    [Parameter] public List<int> ItemIds { get; set; } = new();

    private int _codigoDestinoDigitado = 0;
    private bool _processando = false;
    private string? _erroMesa = null;

    private void Cancelar() => MudDialog.Cancel();

    private async Task Confirmar()
    {
        _erroMesa = null;

        if (_codigoDestinoDigitado == CodigoExternoOrigem)
        {
            _erroMesa = "A mesa de destino não pode ser igual à de origem.";
            return;
        }

        _processando = true;
        try
        {
            var todasMesas = await MesasServices.GetMesaPorPaginaAsync(1, 1000);
            var mesaDestino = todasMesas.Data?.FirstOrDefault(m => m.CodigoExterno == _codigoDestinoDigitado);

            if (mesaDestino is null)
            {
                _erroMesa = $"Nenhuma mesa com código {_codigoDestinoDigitado} encontrada.";
                return;
            }

            var response = await PedidosService.TransferirItensDeMesa(MesaOrigemId, mesaDestino.Id, ItemIds);

            if (response.Status == "success")
            {
                Snackbar.Add(string.Join(", ", response.Data.Messages), Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add(string.Join(", ", response.Messages), Severity.Error);
            }
        }
        finally
        {
            _processando = false;
        }
    }
}
