    private async Task EmiteNFCeAutomatico(ClsPedido pedido)
    {
        var envNFCeDto = new EnNfCeDto { Pedido = pedido };
        var parameters = new DialogParameters<ModalDeCpfNaNota> { { x => x.enNfCeDto, envNFCeDto } };
        var options = new DialogOptions { CloseButton = false, MaxWidth = MaxWidth.ExtraExtraLarge, FullWidth = true, Position = DialogPosition.Center, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<ModalDeCpfNaNota>("Informações Adicionais", parameters, options);
        var result = await dialog.Result;

        if (result!.Canceled) { Snackbar.Add("Emissão de NFC-e cancelada.", Severity.Info); return; }

        _emitindoNF = true;
        _progressoNF = 0;
        _nfProgressCts = new CancellationTokenSource();
        StateHasChanged();

        _ = SimulaProgressoNFAsync(_nfProgressCts.Token);

        try
        {
            var nfResponse = await NFService.GeraNFCe(envNFCeDto);
            var msg = nfResponse.Status == "error"
                ? string.Join(", ", nfResponse.Messages)
                : string.Join(", ", nfResponse.Data?.Messages ?? new List<string>());
            Snackbar.Add(msg, nfResponse.Status == "error" ? Severity.Error : Severity.Success);

            if (nfResponse.Status != "error" && nfResponse.Data?.ObjetoWhenWriting?.XmlStringField is not null)
                await JS.InvokeVoidAsync("baixarXMLNF", nfResponse.Data.ObjetoWhenWriting.XmlStringField, $"{nfResponse.Data.ObjetoWhenWriting.ChaveNf}-procnfe.xml");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao emitir NFC-e: {ex.Message}", Severity.Error);
        }
        finally
        {
            _nfProgressCts?.Cancel();
            _progressoNF = 100;
            StateHasChanged();
            await Task.Delay(300);
            _emitindoNF = false;
            StateHasChanged();
        }
    }

    private async Task SimulaProgressoNFAsync(CancellationToken token)
    {
        while (_progressoNF < 90 && !token.IsCancellationRequested)
        {
            await Task.Delay(120, token).ContinueWith(_ => { });
            _progressoNF = Math.Min(_progressoNF + Random.Shared.Next(2, 6), 90);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task PagarPedidoPorCliente(string nomeCliente)
    {
        var itensDoCliente = PedidoMesa.Itens.Where(x => x.NomeCliente == nomeCliente).ToList();
        if (itensDoCliente.Count == 0) return;

        var subtotalCliente = itensDoCliente.Sum(i => (decimal)i.PrecoTotal);
        var subtotalClienteSemCouvert = itensDoCliente.Where(i => !i.ECouvert).Sum(i => (decimal)i.PrecoTotal);
        var taxaCliente = _cobraTaxa ? subtotalClienteSemCouvert * (TaxaPercent / 100) : 0m;

        ClsPedido NovoPedido = new ClsPedido
        {
            TipoDePedido = "MESA",
            MesaComandaId = MesaOuComanda.Id,
            Itens = itensDoCliente,
            ItensFechamentoIds = itensDoCliente.Where(x => x.Id > 0).Select(x => x.Id).ToList(),
            ServicoValor = (float)taxaCliente,
            CouvertValor = (float)CouvertValor,
        };

        var parameters = new DialogParameters { { "Pedido", NovoPedido } };
        var options = new DialogOptions { Position = DialogPosition.Center, CloseButton = true, MaxWidth = MaxWidth.False, FullWidth = true, CloseOnEscapeKey = true };

        var dialog = await DialogService.ShowAsync<ModalDePagamento>($"Pagamento - Cliente {nomeCliente}", parameters, options);
        var result = await dialog.Result;

        if (!result!.Canceled && result.Data is bool sucesso && sucesso)
        {
            var response = await PedidosService.FechaMesa(NovoPedido);

            if (response.Status == "success")
            {
                Snackbar.Add($"Conta de {nomeCliente} efetuada com sucesso!", Severity.Success);

                if (AppState.MerchantLogado?.EmiteNfAutomatica == true && response.Data?.Objeto is not null)
                    await EmiteNFCeAutomatico(response.Data.Objeto);

                if (itensDoCliente.Count >= PedidoMesa.Itens.Count)
                {
                    MudDialog.Close(DialogResult.Ok(true));
                }
                else
                {
                    ItensSelecionados.Clear();
                    if (dataGridRef is not null)
                        await dataGridRef.ReloadServerData();
                }
            }
            else
            {
                Snackbar.Add($"Erro ao fechar conta de {nomeCliente}: {string.Join(",", response.Messages)}", Severity.Error);
            }
        }
    }
