    #region Função de excluir itens selecionados
    private async Task ExcluirItensSelecionados()
    {
        if (!await AuthorizationService.ValidateAsync("AcessoCancelaItensDaVenda")) return;
        if (ItensSelecionados.Count == 0) return;

        var parameters = new DialogParameters<ModalDeExcluir>
        {
            { x => x.ContentText, $"Deseja excluir {ItensSelecionados.Count} item(ns) selecionado(s)? Essa operação não pode ser desfeita." },
            { x => x.ButtonText, "Sim" },
            { x => x.Color, Color.Error }
        };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<ModalDeExcluir>("Confirmar Exclusão", parameters, options);
        var result = await dialog.Result;
        if (result!.Canceled || result.Data is not bool confirmado || !confirmado) return;

        var erros = new List<string>();
        foreach (var item in ItensSelecionados)
        {
            var response = await PedidosService.ExcluirItemDaMesa(item.Id);
            if (response.Status == "error")
                erros.Add(item.Descricao);
        }

        if (erros.Count == 0)
            Snackbar.Add("Itens excluídos com sucesso!", Severity.Success);
        else
            Snackbar.Add($"Erro ao excluir: {string.Join(", ", erros)}", Severity.Error);

        ItensSelecionados.Clear();

        if (dataGridRef is not null)
            await dataGridRef.ReloadServerData();

        if (PedidoMesa.Itens?.Count == 0)
            MudDialog.Close(DialogResult.Ok(true));
    }
