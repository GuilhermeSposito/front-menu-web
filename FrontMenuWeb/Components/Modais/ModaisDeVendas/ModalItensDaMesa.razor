@rendermode RenderMode.InteractiveWebAssembly
@using System.Text.RegularExpressions
@using System.ComponentModel.DataAnnotations
@using FrontMenuWeb.Components.Modais.ModaisDePessoas
@using FrontMenuWeb.Components.Modais.ModaisGenericos
@inject MesasServices MesasServices
@using FrontMenuWeb.DTOS
@using FrontMenuWeb.Dtos
@using FrontMenuWeb.Models.Merchant
@using FrontMenuWeb.Models.Pedidos
@using FrontMenuWeb.Models.Pessoas
@using FrontMenuWeb.Services
@using FrontMenuWeb.Services.Fiscal
@using FrontMenuWeb.Components.Modais.ModalFiscais
@inject PedidosService AliquotaService
@inject NfService NFService
@inject ProdutoService ProdutoService
@inject GrupoServices GrupoService
@inject PessoasService PessoaService
@inject PedidosService PedidosService
@inject IJSRuntime JS
@inject AuthorizationService AuthorizationService

<MudDialog tabindex="0" OnKeyDown="HandleKeyDownDialog" TitleClass="p-0" ContentClass="p-0" Class="novo-pedido-dialog mud-width-full mud-height-full p-0" Style="background-color: var(--mud-palette-background);">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="p-2" Style="background-color: var(--mud-palette-primary);color:white; box-shadow: 0px 2px 4px rgba(0, 0, 0, 0.1);">
            <MudText Class="ms-3" Typo="Typo.h6">Itens da @AppState.MerchantLogado.LegendaNomeUltilizadoParaPlaced @MesaOuComanda.CodigoExterno</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudButton StartIcon="@Icons.Material.Filled.AddBox" Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" OnClick="AbrirModalDeAdicionarItens">Adicionar Item</MudButton>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Secondary" OnClick="Cancelar" />
            </MudStack>
        </MudStack>
    </TitleContent>
    <DialogContent>

        @* ── Opções de Fechamento ── *@
        @if ((AppState.MerchantLogado?.TaxaDeServicoPercent ?? 0) > 0 || (AppState.MerchantLogado?.AdicionaCouvertComoItem ?? false) || (AppState.MerchantLogado?.ValorCouvert ?? 0) > 0)
        {
            <MudPaper Elevation="0" Class="px-4 py-2 mb-1"
                      Style="background-color:var(--mud-palette-background); border-bottom:1px solid var(--mud-palette-lines-default);">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4" Class="flex-wrap">
                    @if ((AppState.MerchantLogado?.TaxaDeServicoPercent ?? 0) > 0)
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudSwitch @bind-Value="_cobraTaxa" Color="Color.Primary" Size="Size.Large" />
                            <MudText Typo="Typo.h6">Taxa (@(AppState.MerchantLogado!.TaxaDeServicoPercent)%)</MudText>
                            @if (_cobraTaxa)
                            {
                                <MudText Typo="Typo.caption" Style="color:var(--mud-palette-primary);">= @TaxaValor.ToString("C")</MudText>
                            }
                        </MudStack>
                    }
                    @if (!(AppState.MerchantLogado?.AdicionaCouvertComoItem ?? false) && (AppState.MerchantLogado?.ValorCouvert ?? 0) > 0)
                    {
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudSwitch @bind-Value="_cobraCouvert" Color="Color.Secondary" Size="Size.Small" />
                            <MudText Typo="Typo.h6">@AppState.MerchantLogado!.LegendaCouvert (@(AppState.MerchantLogado!.ValorCouvert?.ToString("C"))/pessoa)</MudText>
                            @if (_cobraCouvert)
                            {
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small" Variant="Variant.Outlined"
                                                   OnClick="@(() => _qtdPessoas = Math.Max(1, _qtdPessoas - 1))" />
                                    <MudText Typo="Typo.h6" Style="min-width:20px; text-align:center;">@_qtdPessoas</MudText>
                                    <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" Variant="Variant.Outlined"
                                                   OnClick="@(() => _qtdPessoas++)" />
                                    <MudText Typo="Typo.caption" Style="color:#a78bfa;">= @CouvertValor.ToString("C")</MudText>
                                </MudStack>
                            }
                        </MudStack>
                    }
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudSwitch @bind-Value="_separarPorCliente" Color="Color.Info" Size="Size.Large" />
                        <MudText Typo="Typo.h6">Separar por cliente</MudText>
                    </MudStack>
                    @if (AppState.MerchantLogado?.AdicionaCouvertComoItem ?? false)
                    {
                        <MudButton Size="Size.Large" Variant="Variant.Outlined" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.LocalBar"
                                   OnClick="AbrirFormCouvert">
                            + @AppState.MerchantLogado?.LegendaCouvert
                        </MudButton>
                    }
                    @if (TemExtras)
                    {
                        <MudChip T="string" Color="Color.Success" Size="Size.Large" Variant="Variant.Filled">
                            Total: @TotalGeral.ToString("C")
                        </MudChip>
                    }
                </MudStack>
            </MudPaper>
        }

        @if (_exibeFormCouvert)
        {
            <MudPaper Elevation="2" Class="px-4 py-3 mx-2 my-1" Style="border-left: 4px solid var(--mud-palette-secondary);">
                <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2">Adicionar @AppState.MerchantLogado?.LegendaCouvert</MudText>
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Wrap="Wrap.Wrap">
                        <MudNumericField T="int" @bind-Value="_couvertQtd" Label="Quantidade" Min="1" Step="1"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:130px" HideSpinButtons="false" />
                        <MudNumericField T="decimal" @bind-Value="_couvertValorUnitario" Label="Valor Unitário"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:150px"
                                         Adornment="Adornment.Start" AdornmentText="R$" HideSpinButtons="true" Min="0" Format="N2" />
                        <MudTextField @bind-Value="_couvertNomeCliente" Label="Nome do cliente (opcional)"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:200px"
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Outlined.Person" AdornmentColor="Color.Secondary" />
                    </MudStack>
                    @{
                        var nomesCouvert = PedidoMesa.Itens?
                        .Where(i => !string.IsNullOrEmpty(i.NomeCliente))
                        .Select(i => i.NomeCliente!)
                        .Distinct()
                        .ToList() ?? new();
                    }
                    @if (nomesCouvert.Count > 0)
                    {
                        <MudStack Row="true" Spacing="1" Class="flex-wrap">
                            @foreach (var nome in nomesCouvert)
                            {
                                var nomeCapturado = nome;
                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined"
                                         OnClick="@(() => { _couvertNomeCliente = nomeCapturado; StateHasChanged(); })">
                                    @nomeCapturado
                                </MudChip>
                            }
                        </MudStack>
                    }
                    <MudStack Row="true" Spacing="2">
                        <MudButton OnClick="ConfirmarCouvert" Variant="Variant.Filled" Color="Color.Primary"
                                   Size="Size.Small" Disabled="_salvandoCouvert">
                            @if (_salvandoCouvert)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                            }
                            else
                            {
                                <span>Confirmar</span>
                            }
                        </MudButton>
                        <MudButton OnClick="@(() => _exibeFormCouvert = false)" Variant="Variant.Text" Size="Size.Small">Cancelar</MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>
        }

        @if (!string.IsNullOrEmpty(FiltroCliente))
        {
            <MudPaper Elevation="0" Class="px-4 py-2"
                      Style="background-color:var(--mud-palette-info-darken); color:white;">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                    <MudText Typo="Typo.body2">Exibindo apenas itens de <strong>@FiltroCliente</strong></MudText>
                </MudStack>
            </MudPaper>
        }

        @if (_itemEditando is not null)
        {
            <MudPaper Elevation="2" Class="px-4 py-3 mx-2 my-1" Style="border-left: 4px solid var(--mud-palette-primary);">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Wrap="Wrap.Wrap">
                        <MudTextField @bind-Value="_novaDescricao" Label="Nome do item" Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:220px" />
                        <MudNumericField T="float" @bind-Value="_novaQuantidade" Label="Quantidade" Min="0.001f" Step="1f" Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:120px" />
                        <MudTextField @bind-Value="_novaObservacao" Label="Observação" Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:180px" />
                        <MudTextField @bind-Value="_novoNomeCliente" Label="Cliente" Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:140px" />
                        <MudButton OnClick="SalvarEdicaoItem" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Disabled="_salvandoItem">
                            @if (_salvandoItem)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                            }
                            else
                            {

                                <span>Salvar</span>
                            }
                        </MudButton>
                        <MudButton OnClick="@(() => _itemEditando = null)" Variant="Variant.Text" Size="Size.Small">Cancelar</MudButton>
                    </MudStack>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.caption" Color="Color.Primary">Complementos:</MudText>
                        <MudTooltip Text="@(string.IsNullOrEmpty(_itemEditando?.ProdutoId) ? "Item sem produto vinculado" : "Adicionar complemento")">
                            <MudIconButton Icon="@Icons.Material.Filled.AddCircleOutline"
                                           Size="Size.Small" Color="Color.Primary"
                                           Disabled="@(string.IsNullOrEmpty(_itemEditando?.ProdutoId) || _buscandoProduto)"
                                           OnClick="AbrirModalComplementos" />
                        </MudTooltip>
                        @if (_buscandoProduto)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        }
                    </MudStack>
                    @if (_complementosEditando.Count > 0)
                    {
                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                            @foreach (var comp in _complementosEditando.ToList())
                            {
                                var compCapturado = comp;
                                <MudChip T="string" OnClose="@(() => _complementosEditando.Remove(compCapturado))"
                                         Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">
                                    @comp.Descricao (x@(comp.Quantidade))
                                </MudChip>
                            }
                        </MudStack>
                    }
                </MudStack>
            </MudPaper>
        }

        @if (_itemFracionando is not null)
        {
            <MudPaper Elevation="2" Class="px-4 py-3 mx-2 my-1" Style="border-left: 4px solid var(--mud-palette-warning);">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.subtitle2">
                        Fracionar: <strong>@_itemFracionando.Descricao</strong> &nbsp;
                        <MudText Typo="Typo.h6" Inline="true">(Qtd atual: @_itemFracionando.Quantidade.ToString("G6") | Unit: @_itemFracionando.PrecoUnitario.ToString("C"))</MudText>
                    </MudText>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Wrap="Wrap.Wrap">
                        <MudText Typo="Typo.h6">Frações rápidas:</MudText>
                        @foreach (var frac in new[] { (1, 2, "½"), (1, 3, "⅓"), (2, 3, "⅔"), (1, 4, "¼"), (3, 4, "¾"), (1, 5, "⅕"), (2, 5, "⅖"), (3, 5, "⅗"), (4, 5, "⅘") })
                        {
                            var num = frac.Item1; var den = frac.Item2; var label = frac.Item3;
                            <MudChip T="string" Size="Size.Large" Variant="Variant.Outlined" Color="Color.Warning"
                                     OnClick="@(() => _fracionarQtd = Math.Round((decimal)_itemFracionando.Quantidade * num / den, 3))">
                                @label
                            </MudChip>
                        }
                    </MudStack>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Wrap="Wrap.Wrap">
                        <MudNumericField T="decimal" Value="_fracionarValor" ValueChanged="OnFracionarValorChanged"
                                         Label="Por valor (R$)" Variant="Variant.Outlined" Margin="Margin.Dense"
                                         Min="0.01m" Format="F2" Style="min-width:150px" />
                        <MudNumericField T="decimal" @bind-Value="_fracionarQtd"
                                         Label="Quantidade a separar" Variant="Variant.Outlined" Margin="Margin.Dense"
                                         Min="0.001m" Step="0.001m" Format="F3" Style="min-width:190px" />
                        <MudButton OnClick="ConfirmarFracionamento" Variant="Variant.Filled" Color="Color.Warning"
                                   Size="Size.Small" Disabled="_fracionarSalvando">
                            @if (_fracionarSalvando)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                            }
                            else
                            {
                                <span>Confirmar</span>
                            }
                        </MudButton>
                        <MudButton OnClick="@(() => _itemFracionando = null)" Variant="Variant.Text" Size="Size.Small">Cancelar</MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>
        }

        <MudPaper Elevation="0" Class="px-4 py-2 mb-1"
                  Style="background-color:var(--mud-palette-background); border-bottom:1px solid var(--mud-palette-lines-default);">
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center">
                <MudButton Variant="Variant.Filled" OnClick="ReimprimirPedido" Color="Color.Primary">Reimprimir Itens</MudButton>
                <MudButton OnClick="ImprimirItensSelecionados" Disabled="@(ItensSelecionados.Count == 0)" Variant="Variant.Filled" Color="Color.Primary">Imprimir Selecionados</MudButton>
                <MudButton OnClick="PagarPedido" Variant="Variant.Filled" Color="Color.Primary">Fechar Conta (F3)</MudButton>
                @if (ItensSelecionados.Count > 0 && ItensSelecionados.Count < (PedidoMesa.Itens?.Count ?? 0))
                {
                    <MudButton OnClick="PagarPedidoParcial" Variant="Variant.Filled" Color="Color.Warning">Pagamento Parcial (F6)</MudButton>
                }
                @if (PedidoMesa.Itens != null)
                {
                    var clientes = PedidoMesa.Itens
                    .Where(x => !string.IsNullOrEmpty(x.NomeCliente))
                    .Select(x => x.NomeCliente)
                    .Distinct()
                    .ToList();

                    if (clientes.Count > 1)
                    {
                        @foreach (var cliente in clientes)
                        {
                            <MudButton OnClick="@(() => PagarPedidoPorCliente(cliente!))"
                                       Variant="Variant.Filled"
                                       Color="Color.Info"
                                       StartIcon="@Icons.Material.Filled.Person">
                                Pagar Conta @cliente
                            </MudButton>
                        }
                    }
                }
                @if (ItensSelecionados.Count > 0)
                {
                    <MudButton OnClick="TransferirItensSelecionados" Variant="Variant.Filled" Color="Color.Warning" StartIcon="@Icons.Material.Filled.SwapHoriz">
                        Transferir Selecionados (@ItensSelecionados.Count)
                    </MudButton>
                    <MudButton OnClick="ExcluirItensSelecionados" Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteForever">
                        Excluir Selecionados (@ItensSelecionados.Count)
                    </MudButton>
                }
                <MudButton OnClick="LimparItens" Variant="Variant.Filled" Color="Color.Error">Limpar @AppState.MerchantLogado?.LegendaNomeUltilizadoParaPlaced</MudButton>
            </MudStack>
        </MudPaper>

        @if (_fechandoMesa)
        {
            <MudOverlay Visible="true" DarkBackground="true" ZIndex="9999">
                <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="3">
                    <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Primary" />
                    <MudText Typo="Typo.h6" Style="color:#fff;">Fechando mesa...</MudText>
                </MudStack>
            </MudOverlay>
        }

        @if (_emitindoNF)
        {
            <MudOverlay Visible="true" DarkBackground="true" ZIndex="9999">
                <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="3">
                    <MudProgressCircular Value="@_progressoNF" Size="Size.Large" Color="Color.Primary" />
                    <MudText Typo="Typo.h6" Style="color:#fff;">Emitindo NFC-e...</MudText>
                    <MudProgressLinear Value="@_progressoNF" Color="Color.Primary" Style="width:280px;" />
                    <MudText Typo="Typo.caption" Style="color:#fff;">@_progressoNF%</MudText>
                </MudStack>
            </MudOverlay>
        }

        <MudDataGrid T="ItensPedido"
                     @ref="dataGridRef"
                     MultiSelection=true
                     Class="rounded-3 custom-striped"
                     Loading="Carregando"
                     Hover
                     HorizontalScrollbar="false"
                     ServerData="LoadServerData"
                     SelectedItems="ItensSelecionados"
                     SelectedItemsChanged="ItensSelecionadosChenged"
                     Context="context">
            <NoRecordsContent>
                <AvisoDeDadosVazios ReferenciaDados="Itens da mesa" />
            </NoRecordsContent>
            <Columns>       
                    <SelectColumn T="ItensPedido" />
                    <PropertyColumn Property="x => x.Id" Title="Id"></PropertyColumn>
                    <PropertyColumn Property="x => x.Descricao" Title="Descrição do Item"></PropertyColumn>
                    <PropertyColumn Property="x => x.Quantidade" Title="Quantidade"></PropertyColumn>
                    <PropertyColumn Property="x => x.PrecoUnitario" Format="C" Title="Valor Unit"></PropertyColumn>
                    <PropertyColumn Property="x => x.PrecoTotal" Format="C" Title="Valor Total"></PropertyColumn>
                    <PropertyColumn Property="x => x.NomeCliente" Title="Cliente"></PropertyColumn>
                    <PropertyColumn Property="x => x.CriadoEm" Title="Criado ás" Format="dd/MM/yyyy : HH:mm"></PropertyColumn>
                    @if (AppState.MerchantLogado?.UltilizaRequisicaoDeMesaNoItem ?? false)
                    {
                        <PropertyColumn Property="x => x.NumeroMesaItem" Title="Mesa"></PropertyColumn>
                    }
                    <TemplateColumn Title="Garçom">
                        <CellTemplate>
                            @(context.Item.Garcon?.Nome ?? "Admin")
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Funcionario">
                        <CellTemplate>
                            @(context.Item.Funcionario?.Nome ?? "Admin")
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="" HeaderStyle="width:88px">
                        <CellTemplate>
                            <MudStack Row="true" Spacing="0">
                                <MudIconButton Icon="@Icons.Material.Filled.CallSplit" Size="Size.Small" Color="Color.Warning"
                                               OnClick="@(() => AbrirFracionamento(context.Item))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                               OnClick="@(() => AbrirEdicaoItem(context.Item))" />
                            </MudStack>
                        </CellTemplate>
                    </TemplateColumn>
            </Columns>
        </MudDataGrid>

    </DialogContent>
</MudDialog>



@code {
    #region Propriedades
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter] public ClsMesasEComandas MesaOuComanda { get; set; } = new ClsMesasEComandas() { CodigoExterno = 0 };
    [Parameter] public string? FiltroCliente { get; set; }

    private PedidoMesaDto PedidoMesa { get; set; } = new PedidoMesaDto();
    private MudDataGrid<ItensPedido>? dataGridRef = new();

    private bool Carregando { get; set; } = true;

    // ── NF automática ──
    private bool _fechandoMesa = false;
    private bool _emitindoNF = false;
    private int _progressoNF = 0;
    private CancellationTokenSource? _nfProgressCts;

    // ── Opções de fechamento ──
    private bool _cobraTaxa = false;
    private bool _cobraCouvert = false;
    private int _qtdPessoas = 1;
    private bool _separarPorCliente = true;

    private decimal SubTotalItens => (PedidoMesa.Itens?.Sum(i => (decimal)i.PrecoTotal)) ?? 0m;
    private decimal SubTotalParaTaxa => ItensSelecionados.Count > 0
        ? ItensSelecionados.Sum(i => (decimal)i.PrecoTotal)
        : SubTotalItens;
    private decimal SubTotalSemCouvert => ItensSelecionados.Count > 0
        ? ItensSelecionados.Where(i => !i.ECouvert).Sum(i => (decimal)i.PrecoTotal)
        : (PedidoMesa.Itens?.Where(i => !i.ECouvert).Sum(i => (decimal)i.PrecoTotal) ?? 0m);
    private decimal TaxaPercent => (decimal)(AppState.MerchantLogado?.TaxaDeServicoPercent ?? 0);
    private decimal TaxaValor => _cobraTaxa ? SubTotalSemCouvert * (TaxaPercent / 100) : 0m;
    private decimal CouvertPorPessoa => (decimal)(AppState.MerchantLogado?.ValorCouvert ?? 0);
    private decimal CouvertValor => _cobraCouvert ? CouvertPorPessoa * _qtdPessoas : 0m;
    private decimal TotalGeral => SubTotalParaTaxa + TaxaValor + CouvertValor;
    private bool TemExtras => TaxaValor > 0 || CouvertValor > 0;
    #endregion

    #region Funções de Inicialização
    protected override async Task OnInitializedAsync()
    {
        try
        {
            _cobraTaxa = (AppState.MerchantLogado?.TaxaDeServicoPercent ?? 0) > 0;
            _cobraCouvert = (AppState.MerchantLogado?.ValorCouvert ?? 0) > 0 && !(AppState.MerchantLogado?.AdicionaCouvertComoItem ?? false);

            PedidosService.PedidoMesaRecebido += async pedido =>
            {
                await InvokeAsync(() => OnPedidoMesaRecebido(pedido));
            };

            await CarregaMesaOuComanda();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao carregar dados: {ex.Message}", Severity.Error);
        }
        finally
        {
            Carregando = false;
        }
    }

    private async Task CarregaMesaOuComanda()
    {
        if (MesaOuComanda.CodigoExterno != 0)
        {
            var mesa = await PedidosService.GetMesaOcupada(MesaOuComanda.Id);

            if (mesa.Status == "success")
            {
                PedidoMesa = mesa.Data.Objeto ?? throw new Exception("Pedido não encontrado");
            }
        }
    }
    #endregion

    #region Funções da Página
    private async void Cancelar()
    {
        MudDialog.Cancel();
    }

    private async Task AbrirModalDeAdicionarItens()
    {
        var parameters = new DialogParameters
        {
            { "TiposDePedido", TiposDePedido.MESA },
            { "Mesa", MesaOuComanda }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.False, FullWidth = false, FullScreen = false, CloseOnEscapeKey = true, BackdropClick = false };
        var dialog = await DialogService.ShowAsync<ModalDeCriarPedido>("Adicionar Itens", parameters, options);
        var result = await dialog.Result;

        if (!result!.Canceled && result.Data is bool sucesso && sucesso)
        {
            if (dataGridRef is not null)
                await dataGridRef.ReloadServerData();
        }
    }

    private async Task HandleKeyDownDialog(KeyboardEventArgs e)
    {
        if (e.CtrlKey && e.AltKey)
        {

        }

        if (e.Key == "F3")
        {
            await JS.InvokeVoidAsync("event.preventDefault");
            await PagarPedido();
        }

        if (e.Key == "F6")
        {
            await JS.InvokeVoidAsync("event.preventDefault");
            await PagarPedidoParcial();
        }
    }

    private async Task OnPedidoMesaRecebido(PedidoMesaDto novoPedido)
    {
        if (dataGridRef is not null)
            await dataGridRef.ReloadServerData();
    }
    #endregion

    #region Funções DataGrid
    private async Task<GridData<ItensPedido>> LoadServerData(GridState<ItensPedido> itens)
    {
        try
        {
            Carregando = true;

            int page = itens.Page + 1;
            int pageSize = itens.PageSize;


            var result = await PedidosService
                                            .GetMesaOcupada(MesaOuComanda.Id);

            if (result.Status == "success")
            {
                PedidoMesa = result.Data.Objeto ?? new();
            }

            // PedidoMesa.Itens mantém TODOS os itens (necessário para o cálculo de parcial)
            var todosItens = PedidoMesa.Itens ?? new List<ItensPedido>();

            var itensMostrados = string.IsNullOrEmpty(FiltroCliente)
                ? todosItens
                : todosItens.Where(i => i.NomeCliente == FiltroCliente).ToList();

            if (!string.IsNullOrEmpty(FiltroCliente))
                ItensSelecionados = itensMostrados.ToHashSet();

            StateHasChanged();

            return new GridData<ItensPedido>
            {
                Items = itensMostrados,
                TotalItems = itensMostrados.Count
            };

        }
        catch (HttpRequestException ex)
        {
            return new GridData<ItensPedido>
            {

            };

        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao carregar lançamentos: {ex.Message}", Severity.Error);
            return new GridData<ItensPedido>
            {

            };

        }
        finally
        {
            Carregando = false;
        }
    }

