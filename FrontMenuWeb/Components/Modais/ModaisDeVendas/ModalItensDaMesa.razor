    // ── Fracionamento de item ──
    private ItensPedido? _itemFracionando = null;
    private decimal _fracionarQtd = 0m;
    private decimal _fracionarValor = 0m;
    private bool _fracionarSalvando = false;

    private void AbrirFracionamento(ItensPedido item)
    {
        _itemFracionando = item;
        _itemEditando = null;
        _fracionarQtd = 0m;
        _fracionarValor = 0m;
    }

    private void OnFracionarValorChanged(decimal valor)
    {
        _fracionarValor = valor;
        if (_itemFracionando is not null && _itemFracionando.PrecoUnitario > 0 && valor > 0)
            _fracionarQtd = Math.Round(valor / (decimal)_itemFracionando.PrecoUnitario, 3);
    }

    private async Task ConfirmarFracionamento()
    {
        if (_itemFracionando is null || _fracionarQtd <= 0) return;
        if (_fracionarQtd >= (decimal)_itemFracionando.Quantidade)
        {
            Snackbar.Add("A quantidade a separar deve ser menor que a quantidade atual do item.", Severity.Warning);
            return;
        }
        _fracionarSalvando = true;
        try
        {
            ItensSelecionados.Clear();
            var result = await PedidosService.FracionarItemMesa(MesaOuComanda.Id, _itemFracionando.Id, _fracionarQtd);
            if (result?.Status == "success")
            {
                Snackbar.Add("Item fracionado com sucesso.", Severity.Success);
                _itemFracionando = null;
                _fracionarQtd = 0m;
                _fracionarValor = 0m;
                if (dataGridRef is not null)
                    await dataGridRef.ReloadServerData();
            }
            else
                Snackbar.Add(string.Join(", ", result?.Messages ?? new()), Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro: {ex.Message}", Severity.Error);
        }
        finally
        {
            _fracionarSalvando = false;
        }
    }

