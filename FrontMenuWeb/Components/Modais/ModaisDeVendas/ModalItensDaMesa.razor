    private void AbrirEdicaoItem(ItensPedido item)
    {
        _itemFracionando = null;
        _itemEditando = item;
        _novaDescricao = item.Descricao ?? string.Empty;
        _novaQuantidade = item.Quantidade;
        _novaObservacao = item.Observacoes;
        _novoNomeCliente = item.NomeCliente;
        _complementosEditando = item.Complementos?.Select(c => new ComplementoNoItem
        {
            Id = c.Id,
            ComplementoId = c.ComplementoId,
            Descricao = c.Descricao,
            Quantidade = c.Quantidade,
            PrecoUnitario = c.PrecoUnitario,
            PrecoTotal = c.PrecoTotal
        }).ToList() ?? new();

        if (_produtoParaComplementos?.Id != item.ProdutoId)
            _produtoParaComplementos = null;
    }

    private async Task AbrirModalComplementos()
    {
        if (string.IsNullOrEmpty(_itemEditando?.ProdutoId)) return;

        if (_produtoParaComplementos?.Id != _itemEditando.ProdutoId)
        {
            _buscandoProduto = true;
            StateHasChanged();
            _produtoParaComplementos = await ProdutoService.GetProdutoAsync(_itemEditando.ProdutoId);
            _buscandoProduto = false;
            StateHasChanged();
        }

        if (_produtoParaComplementos is null ||
            _produtoParaComplementos.GruposDeComplementosDoProduto is null ||
            !_produtoParaComplementos.GruposDeComplementosDoProduto.Any())
        {
            Snackbar.Add("Este produto não possui grupos de complementos cadastrados.", Severity.Warning);
            return;
        }

        var parameters = new DialogParameters<ModalDeAdicionarComplementoAoItem>
        {
            { x => x.Produto, _produtoParaComplementos }
        };
        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };
        var dialog = await DialogService.ShowAsync<ModalDeAdicionarComplementoAoItem>("Adicionar Complemento", parameters, options);
        var result = await dialog.Result;

        if (!result!.Canceled && result.Data is List<ComplementoNoItem> novos && novos.Count > 0)
        {
            foreach (var novo in novos)
            {
                var existente = _complementosEditando.FirstOrDefault(c => c.ComplementoId == novo.ComplementoId);
                if (existente is not null)
                {
                    existente.Quantidade += novo.Quantidade;
                    existente.PrecoTotal = existente.PrecoUnitario * existente.Quantidade;
                }
                else
                {
                    _complementosEditando.Add(novo);
                }
            }
            StateHasChanged();
        }
    }

    private async Task SalvarEdicaoItem()
    {
        if (_itemEditando is null) return;
        if (_novaQuantidade <= 0)
        {
            Snackbar.Add("A quantidade deve ser maior que zero.", Severity.Warning);
            return;
        }

        var complementosDto = _complementosEditando.Select(c => (object)new
        {
            Id = c.Id,
            ComplementoId = c.ComplementoId,
            Descricao = c.Descricao,
            Quantidade = c.Quantidade,
            PrecoUnitario = c.PrecoUnitario
        }).ToList();

        _salvandoItem = true;
        var ok = await PedidosService.UpdateItemMesaAsync(
            _itemEditando.Id,
            _novaDescricao,
            _novaQuantidade,
            _novaObservacao,
            _novoNomeCliente,
            complementosDto);
        _salvandoItem = false;

        if (ok)
        {
            Snackbar.Add("Item atualizado com sucesso!", Severity.Success);
            _itemEditando = null;
            if (dataGridRef is not null)
                await dataGridRef.ReloadServerData();
        }
        else
        {
            Snackbar.Add("Erro ao atualizar o item.", Severity.Error);
        }
    }

