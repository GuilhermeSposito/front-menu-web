@rendermode RenderMode.InteractiveWebAssembly
@using FrontMenuWeb.Models.Merchant
@using FrontMenuWeb.Services
@inject PedidosService PedidosService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Juntar @(AppState.MerchantLogado?.LegendaNomeUltilizadoParaPlaced ?? "Mesas")</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            @if (_etapa == 1)
            {
                <MudText Typo="Typo.body2">
                    Selecione duas @(AppState.MerchantLogado?.LegendaNomeUltilizadoParaPlaced ?? "mesas") ocupadas para juntar.
                    <strong>Selecionadas: @_selecionadas.Count / 2</strong>
                </MudText>
                <MudGrid Spacing="2">
                    @foreach (var mesa in MesasOcupadas)
                    {
                        var selecionada = _selecionadas.Contains(mesa.Id);
                        <MudItem xs="6" sm="4" md="3">
                            <MudCard Class="rounded-3 text-center cursor-pointer"
                                     Style="@(selecionada ? "background-color: #1976D2; color: #FFFFFF; border: 3px solid #0D47A1;" : mesa.AguardandoPagamento ? "background-color: #FFC107; color: #000000;" : "background-color: #FF0024; color: #FFFFFF;")"
                                     @onclick="() => ToggleMesa(mesa.Id)">
                                <MudCardContent>
                                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold">
                                        @(AppState.MerchantLogado?.LegendaNomeUltilizadoParaPlaced ?? "Mesa")
                                    </MudText>
                                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold">
                                        @mesa.CodigoExterno.ToString().PadLeft(2, '0')
                                    </MudText>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            }
            else
            {
                var nomeA = MesasOcupadas.FirstOrDefault(m => m.Id == _selecionadas[0])?.CodigoExterno.ToString().PadLeft(2, '0');
                var nomeB = MesasOcupadas.FirstOrDefault(m => m.Id == _selecionadas[1])?.CodigoExterno.ToString().PadLeft(2, '0');
                <MudText Typo="Typo.body2">
                    Juntando as @(AppState.MerchantLogado?.LegendaNomeUltilizadoParaPlaced ?? "mesas") <strong>@nomeA</strong> e <strong>@nomeB</strong>.
                    Qual delas mantém o consumo?
                </MudText>
                <MudStack Row="true" Spacing="3" Justify="Justify.Center">
                    @foreach (var id in _selecionadas)
                    {
                        var mesa = MesasOcupadas.FirstOrDefault(m => m.Id == id);
                        if (mesa is null) continue;
                        var escolhida = _mesaFinalId == id;
                        <MudCard Class="rounded-3 text-center cursor-pointer"
                                 Style="@(escolhida ? "background-color: #1976D2; color: #FFFFFF; border: 3px solid #0D47A1; min-width: 100px;" : "background-color: #FF0024; color: #FFFFFF; min-width: 100px;")"
                                 @onclick="() => _mesaFinalId = id">
                            <MudCardContent>
                                <MudText Typo="Typo.subtitle1" Class="font-weight-bold">
                                    @(AppState.MerchantLogado?.LegendaNomeUltilizadoParaPlaced ?? "Mesa")
                                </MudText>
                                <MudText Typo="Typo.subtitle1" Class="font-weight-bold">
                                    @mesa.CodigoExterno.ToString().PadLeft(2, '0')
                                </MudText>
                                @if (escolhida)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" />
                                }
                            </MudCardContent>
                        </MudCard>
                    }
                </MudStack>
                @if (_erroFinal is not null)
                {
                    <MudText Color="Color.Error" Typo="Typo.caption">@_erroFinal</MudText>
                }
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Variant="Variant.Text">Cancelar</MudButton>
        @if (_etapa == 1)
        {
            <MudButton OnClick="AvancarEtapa"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="@(_selecionadas.Count != 2)">
                Próximo
            </MudButton>
        }
        else
        {
            <MudButton OnClick="VoltarEtapa" Variant="Variant.Text">Voltar</MudButton>
            <MudButton OnClick="Confirmar"
                       Variant="Variant.Filled"
                       Color="Color.Warning"
                       Disabled="@(_processando || _mesaFinalId == 0)">
                @if (_processando)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                }
                Juntar
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public List<ClsMesasEComandas> MesasOcupadas { get; set; } = new();

    private int _etapa = 1;
    private List<int> _selecionadas = new();
    private int _mesaFinalId = 0;
    private bool _processando = false;
    private string? _erroFinal = null;

    private void ToggleMesa(int id)
    {
        if (_selecionadas.Contains(id))
        {
            _selecionadas.Remove(id);
        }
        else if (_selecionadas.Count < 2)
        {
            _selecionadas.Add(id);
        }
    }

    private void AvancarEtapa()
    {
        if (_selecionadas.Count != 2) return;
        _mesaFinalId = 0;
        _erroFinal = null;
        _etapa = 2;
    }

    private void VoltarEtapa()
    {
        _etapa = 1;
        _mesaFinalId = 0;
        _erroFinal = null;
    }

    private void Cancelar() => MudDialog.Cancel();

    private async Task Confirmar()
    {
        _erroFinal = null;

        if (_mesaFinalId == 0)
        {
            _erroFinal = "Selecione qual mesa mantém o consumo.";
            return;
        }

        _processando = true;
        try
        {
            var response = await PedidosService.JuntarMesas(_selecionadas, _mesaFinalId);

            if (response.Status == "success")
            {
                Snackbar.Add(string.Join(", ", response.Data.Messages), Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add(string.Join(", ", response.Messages), Severity.Error);
            }
        }
        finally
        {
            _processando = false;
        }
    }
}
