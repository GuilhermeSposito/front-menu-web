@rendermode RenderMode.InteractiveWebAssembly
@attribute [Authorize]
@using System.Text.RegularExpressions
@using System.ComponentModel.DataAnnotations
@using FrontMenuWeb.Components.Modais.ModaisDePessoas
@using FrontMenuWeb.DTOS
@using FrontMenuWeb.Models.Integracoes
@using FrontMenuWeb.Services
@using System.Globalization
@inject IJSRuntime JS
@inject EmpresaIfoodService EmpresasIfoodServices

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" sm="12" md="12" lg="12">
                <MudTextField @bind-Value=Empresa.NomeEmpresa Label="Nome Identificador" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12" sm="12" md="12" lg="12">
                <MudTextField @bind-Value=Empresa.MerchantIdIfood Label="ID Empresa Ifood" Variant="Variant.Outlined" />
            </MudItem>


            <MudItem xs="12" sm="12" md="12" lg="12">
                <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center">
                    <MudButton Color="Color.Primary" OnClick=AdicionarEmpresa Variant="Variant.Filled">Adicionar Empresa</MudButton>
                </MudStack>
            </MudItem>




        </MudGrid>

    </DialogContent>
</MudDialog>


@code {
    #region Propriedades
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter] public ClsEmpresaIfood Empresa { get; set; } = new ClsEmpresaIfood();
    private UserCodeReturnFromAPIIfoodDto? ObjetoRetornadoDaAutorizacaoDoIfood { get; set; } = null;
    #endregion

    #region Funções de Ações
    public async Task AdicionarEmpresa()
    {
        if (!string.IsNullOrEmpty(Empresa.MerchantIdIfood))
        {
            var response = await EmpresasIfoodServices.CreateEmpresa(Empresa);
            if (response.Status == "success")
            {
                Snackbar.Add("Empresa Ifood adicionada com sucesso", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add(string.Join(",", response.Messages), Severity.Error);
                return;
            }
        }
        else
        {
            Snackbar.Add("Preencha o campo Merchant ID Ifood", Severity.Error);
        }
    }

    #endregion

}