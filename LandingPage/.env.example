# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ──────────────────────────────────────────
# Configurações do servidor de e-mail (SMTP)
# ──────────────────────────────────────────

# Porta do servidor backend Express (padrão: 3001)
SERVER_PORT=3001

# Host SMTP — ex: smtp.gmail.com | smtp.office365.com | mail.seudominio.com
SMTP_HOST="smtp.gmail.com"

# Porta SMTP — 587 (TLS/STARTTLS) ou 465 (SSL)
SMTP_PORT=587

# Use "true" apenas se a porta for 465 (SSL direto)
SMTP_SECURE=false

# Usuário e senha do e-mail remetente
SMTP_USER="seuemail@gmail.com"
SMTP_PASS="sua_senha_de_app"

# E-mail que receberá as solicitações de orçamento
EMAIL_DESTINATARIO="contato@sophosapp.com.br"
