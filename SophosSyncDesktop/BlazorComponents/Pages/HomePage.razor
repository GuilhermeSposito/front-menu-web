@page "/"

<div style="display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%; padding:48px;">

    <MudImage Src="/images/SOPHOS.png" Width="180" Style="margin-bottom:32px;" />

    <MudText Typo="Typo.h4" Align="Align.Center" Style="font-weight:700; color:var(--mud-palette-text-primary);">
        Bem-vindo ao Sophos Desktop
